---
import { footerColumns } from '../data/siteContent';
---
<footer class="dark:border-stone-800 dark:bg-[#1c1917] z-10 bg-[#F5F0E6] border-stone-200 border-t mt-auto pt-16 pb-8 relative reveal" id="global-footer">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 lg:gap-8 mb-16">
      
      <div class="col-span-1 md:col-span-2 lg:col-span-1">
        <h4 class="font-mono text-xs font-semibold uppercase tracking-wider text-stone-900 dark:text-stone-100 mb-6">Binizam</h4>
        <p class="leading-7 dark:text-stone-400 text-sm text-stone-500">
          Accounts receivable automation and workflow systems for GCC finance teams. Retool-first, ERP-connected, built for traceability.
        </p>
      </div>
      
      {footerColumns.map((column) => (
        <div>
          <h4 class="font-mono text-xs font-semibold uppercase tracking-wider text-stone-900 dark:text-stone-100 mb-6">
            {column.title}
          </h4>
          <div class="flex flex-col gap-3">
            {column.links.map((link) => (
              <a
                class="text-sm text-stone-500 dark:text-stone-400 hover:text-[#D97706] dark:hover:text-[#D97706] transition-colors duration-200"
                href={link.href}
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
      ))}
      
    </div>
    
    <div class="pt-8 border-t border-stone-200 dark:border-stone-800 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <p class="text-xs text-stone-500 dark:text-stone-500">© 2026 BINIZAM. All rights reserved.</p>
      <p class="text-xs text-stone-400 dark:text-stone-600">Not an ERP replacement · Not a payments provider</p>
    </div>
  </div>
</footer>
