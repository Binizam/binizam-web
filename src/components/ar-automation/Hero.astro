---
const heroNodes = [
  { icon: "solar:clipboard-list-linear", title: "Worklist", desc: "Prioritize next actions", margin: "" },
  { icon: "solar:shield-warning-linear", title: "Exceptions", desc: "Route out-of-sync events", margin: "ml-8" },
  { icon: "solar:check-read-linear", title: "Approvals", desc: "Manager review & audit", margin: "ml-16", active: true }
];
---
<a href="/contact" class="fixed bottom-8 right-8 z-50 flex items-center justify-center w-14 h-14 rounded-full bg-amber-600 hover:bg-amber-700 text-white shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group reveal delay-500">
  <iconify-icon icon="solar:chat-round-dots-linear" width="28" height="28" stroke-width="1.5"></iconify-icon>
</a>

<section class="min-h-[70vh] flex max-w-6xl mx-auto pt-24 px-6 pb-24 items-center">
  <div class="grid lg:grid-cols-2 gap-16 w-full items-center">
    <div class="max-w-xl z-20 relative order-2 lg:order-1">
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-primary dark:text-stone-50 leading-[1.1] mb-6 reveal">
        AR Collections Automation
      </h1>
      <p class="text-lg text-muted dark:text-stone-400 leading-relaxed mb-4 reveal delay-100">
        We build AR collections workflows that make follow-ups, disputes, and reconciliation predictable and traceable—alongside your ERP, without handling payments.
      </p>
      <p class="text-sm text-stone-500 dark:text-stone-500 mb-8 reveal delay-200">
        This is our most common starting point. For the full map of what we deliver, see <a href="/capabilities" class="text-amber-600 hover:text-amber-700 hover:underline underline-offset-4 transition-colors">Capabilities</a>.
      </p>
      
      <div class="reveal delay-300 flex flex-col gap-6">
        <a href="/contact" class="md:hidden inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-white bg-amber-600 hover:bg-amber-700 rounded-lg transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 w-fit">
          Start a fit check
        </a>

        <div class="hidden md:flex flex-col gap-4">
          <div class="flex flex-wrap items-center gap-3">
            <span class="text-xs font-medium text-stone-400 dark:text-stone-500 mr-1">Quick jumps:</span>
            <a href="#what-it-includes" class="px-3 py-1.5 text-xs font-medium text-primary dark:text-stone-300 bg-surface/50 dark:bg-stone-800/50 border border-stone-200 dark:border-stone-700 rounded-full hover:border-amber-600/40 hover:text-amber-600 hover:-translate-y-0.5 hover:shadow-sm transition-all">What it includes</a>
            <a href="#signs-you-need-this" class="px-3 py-1.5 text-xs font-medium text-primary dark:text-stone-300 bg-surface/50 dark:bg-stone-800/50 border border-stone-200 dark:border-stone-700 rounded-full hover:border-amber-600/40 hover:text-amber-600 hover:-translate-y-0.5 hover:shadow-sm transition-all">Signs you need this</a>
            <a href="#typical-workflows" class="px-3 py-1.5 text-xs font-medium text-primary dark:text-stone-300 bg-surface/50 dark:bg-stone-800/50 border border-stone-200 dark:border-stone-700 rounded-full hover:border-amber-600/40 hover:text-amber-600 hover:-translate-y-0.5 hover:shadow-sm transition-all">Typical workflows</a>
          </div>
          <p class="text-xs text-stone-400 dark:text-stone-500 font-medium">15–20 min fit check • Reply in 1–2 business days</p>
        </div>
      </div>
    </div>

    <div class="relative w-full h-[400px] flex items-center justify-center order-1 lg:order-2 reveal delay-200 select-none">
      <div class="relative flex flex-col gap-8 w-full max-w-sm ml-auto mr-auto lg:mr-0">
        <div class="absolute left-10 top-12 bottom-12 w-[2px] dash-line text-stone-200 dark:text-stone-800 z-0"></div>
        {heroNodes.map(node => (
          <div class={`flex items-center gap-6 relative z-10 group cursor-default ${node.margin}`}>
            <div class={`w-20 h-20 rounded-2xl border shadow-sm flex items-center justify-center transition-all group-hover:shadow-lg group-hover:-translate-y-1 ${
              node.active 
                ? 'bg-surface/50 dark:bg-stone-900 border-amber-600/30 dark:border-amber-600/40 text-amber-600 group-hover:border-amber-500' 
                : 'bg-main dark:bg-stone-950 border-stone-200 dark:border-stone-800 text-muted group-hover:border-amber-500/50 group-hover:text-amber-600'
            }`}>
              <iconify-icon icon={node.icon} width="32" stroke-width="1.5"></iconify-icon>
            </div>
            <div class="flex-1">
              <h3 class="text-base font-semibold text-primary dark:text-stone-100 tracking-tight">{node.title}</h3>
              <p class="text-xs text-muted dark:text-stone-500 mt-1">{node.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style is:global>
  .dash-line {
    background-image: linear-gradient(to bottom, currentColor 50%, transparent 50%);
    background-size: 2px 12px;
    background-repeat: repeat-y;
  }
</style>