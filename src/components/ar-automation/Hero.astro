---
import { getLocaleFromPath, type Locale } from '../../lib/i18n';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale || getLocaleFromPath(Astro.url.pathname);
const isAr = locale === 'ar';
const copy = isAr ? {
  contactHref: '/ar/contact',
  title: 'أتمتة تحصيل الذمم المدينة فوق ERP',
  paragraphs: [
    'تبني بنظام سير عمل لتحصيل الذمم المدينة لفرق المالية في الخليج التي تحتاج إلى تنفيذ محكوم حول ERP.',
    'تستخدمه الفرق لقوائم التحصيل، المتابعة، النزاعات ووعود السداد، مطابقة المدفوعات، إشعارات السداد، تخصيص المقبوضات، قوائم التسوية، استثناءات الإدارة، وسجلات التدقيق.',
    'مناسب لأتمتة تحصيل الذمم المدينة في الإمارات والخليج، وليس برنامج تحصيل عام، وليس بديلًا عن ERP، وليس مزود مدفوعات.'
  ],
  primary: 'تحدّث مع مهندس',
  secondary: 'حالة موزعي السلع الاستهلاكية',
  secondaryHref: '/ar/ar-collections/fmcg-distributors-uae',
  quickLabel: 'روابط سريعة:',
  quickJumps: [
    { href: '#what-it-includes', label: 'ما الذي يشمله؟' },
    { href: '#best-fit', label: 'الشركات الأنسب' },
    { href: '#industry-use-cases', label: 'حالات حسب القطاع' },
    { href: '#first-version-scope', label: 'أول نطاق' },
    { href: '#faq', label: 'أسئلة شائعة' }
  ],
  smallLine: 'فحص ملاءمة خلال 15–20 دقيقة · رد خلال يوم إلى يومي عمل',
  nodes: [
    { icon: 'solar:clipboard-list-linear', title: 'قائمة عمل', desc: 'ترتيب الإجراءات التالية', margin: '' },
    { icon: 'solar:shield-warning-linear', title: 'استثناءات', desc: 'توجيه الحالات غير المتطابقة', margin: 'lg:mr-8' },
    { icon: 'solar:check-read-linear', title: 'موافقات', desc: 'مراجعة الإدارة وسجل التدقيق', margin: 'lg:mr-16', active: true }
  ]
} : {
  contactHref: '/contact',
  title: 'AR collections automation above your ERP',
  paragraphs: [
    'Binizam builds accounts receivable automation for GCC finance teams that need controlled AR collections execution around the ERP.',
    'Teams use it for credit-control workflows, collections follow-up, disputes/PTPs, payment matching, remittance handling, receipt allocation, reconciliation queues, manager exceptions, and audit trails.',
    'Useful for AR automation in the UAE and GCC, billing-to-cash workflow automation, and better dunning workflow control. Not generic dunning software, not an ERP replacement, and not a payments provider.'
  ],
  primary: 'Talk to an engineer',
  secondary: 'See FMCG distributor use case',
  secondaryHref: '/ar-collections/fmcg-distributors-uae',
  quickLabel: 'Quick jumps:',
  quickJumps: [
    { href: '#what-it-includes', label: 'What it includes' },
    { href: '#best-fit', label: 'Best-fit companies' },
    { href: '#industry-use-cases', label: 'Industry use cases' },
    { href: '#first-version-scope', label: 'First version scope' },
    { href: '#faq', label: 'FAQs' }
  ],
  smallLine: '15–20 min fit check · Reply in 1–2 business days',
  nodes: [
    { icon: 'solar:clipboard-list-linear', title: 'Worklist', desc: 'Prioritize next actions', margin: '' },
    { icon: 'solar:shield-warning-linear', title: 'Exceptions', desc: 'Route out-of-sync events', margin: 'lg:ml-8' },
    { icon: 'solar:check-read-linear', title: 'Approvals', desc: 'Manager review & audit', margin: 'lg:ml-16', active: true }
  ]
};
---

<a href={copy.contactHref} class={`hidden lg:flex fixed bottom-8 ${isAr ? 'left-8' : 'right-8'} z-50 items-center justify-center w-14 h-14 rounded-full bg-amber-600 hover:bg-amber-700 text-white shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group reveal delay-500`}>
  <iconify-icon icon="solar:chat-round-dots-linear" width="28" height="28" stroke-width="1.5"></iconify-icon>
</a>

<section class="min-h-0 lg:min-h-[70vh] flex max-w-6xl mx-auto pt-24 px-6 pb-12 lg:pb-24 items-center" dir={isAr ? 'rtl' : 'ltr'}>
  <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 w-full items-center">
    <div class={`w-full min-w-0 max-w-xl z-20 relative order-1 lg:order-1 flex flex-col items-center ${isAr ? 'lg:items-end lg:text-right' : 'lg:items-start lg:text-left'} text-center`}>
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-primary dark:text-stone-50 leading-[1.1] mb-6 reveal">
        {copy.title}
      </h1>
      <p class="text-lg text-muted dark:text-stone-400 leading-relaxed mb-4 reveal delay-100 max-w-lg lg:max-w-none">
        {copy.paragraphs[0]}
      </p>
      <p class="text-lg text-muted dark:text-stone-400 leading-relaxed mb-4 reveal delay-200 max-w-lg lg:max-w-none">
        {copy.paragraphs[1]}
      </p>
      <p class="text-sm text-stone-500 dark:text-stone-500 mb-8 reveal delay-200 max-w-lg lg:max-w-none">
        {copy.paragraphs[2]}
      </p>

      <div class={`reveal delay-300 flex flex-col gap-6 w-full items-center ${isAr ? 'lg:items-end' : 'lg:items-start'}`}>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={copy.contactHref} class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-white bg-amber-600 hover:bg-amber-700 rounded-lg transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 w-fit">
            {copy.primary}
          </a>
          <a href={copy.secondaryHref} class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-primary bg-transparent border border-primary/20 hover:border-primary/50 dark:text-stone-100 dark:border-stone-700 dark:hover:border-stone-500 rounded-lg transition-all w-fit">
            {copy.secondary}
          </a>
        </div>

        <div class={`hidden md:flex flex-col gap-4 items-center ${isAr ? 'lg:items-end' : 'lg:items-start'}`}>
          <div class={`flex flex-wrap items-center justify-center ${isAr ? 'lg:justify-end' : 'lg:justify-start'} gap-3`}>
            <span class="text-xs font-medium text-stone-400 dark:text-stone-500">{copy.quickLabel}</span>
            {copy.quickJumps.map((jump) => (
              <a href={jump.href} class="px-3 py-1.5 text-xs font-medium text-primary dark:text-stone-300 bg-surface/50 dark:bg-stone-800/50 border border-stone-200 dark:border-stone-700 rounded-full hover:border-amber-600/40 hover:text-amber-600 hover:-translate-y-0.5 hover:shadow-sm transition-all">{jump.label}</a>
            ))}
          </div>
          <p class="text-xs text-stone-400 dark:text-stone-500 font-medium">{copy.smallLine}</p>
        </div>
      </div>
    </div>

    <div class="relative w-full min-w-0 h-auto py-12 lg:py-0 lg:h-[400px] flex items-center justify-center order-2 lg:order-2 reveal delay-200 select-none">
      <div class={`relative flex flex-col gap-8 w-full max-w-sm mx-auto ${isAr ? 'lg:ml-0 text-right' : 'lg:mr-0 text-left'}`}>
        <div class={`absolute ${isAr ? 'right-10' : 'left-10'} top-12 bottom-12 w-[2px] dash-line text-stone-200 dark:text-stone-800 z-0`}></div>
        {copy.nodes.map(node => (
          <div class={`flex items-center gap-6 relative z-10 group cursor-default ${node.margin}`}>
            <div class={`w-20 h-20 rounded-2xl border shadow-sm flex items-center justify-center transition-all group-hover:shadow-lg group-hover:-translate-y-1 ${
              node.active
                ? 'bg-surface/50 dark:bg-stone-900 border-amber-600/30 dark:border-amber-600/40 text-amber-600 group-hover:border-amber-500'
                : 'bg-main dark:bg-stone-950 border-stone-200 dark:border-stone-800 text-muted group-hover:border-amber-500/50 group-hover:text-amber-600'
            }`}>
              <iconify-icon icon={node.icon} width="32" stroke-width="1.5"></iconify-icon>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-primary dark:text-stone-100 tracking-tight">{node.title}</h3>
              <p class="text-xs text-muted dark:text-stone-500 mt-1">{node.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style is:global>
  .dash-line {
    background-image: linear-gradient(to bottom, currentColor 50%, transparent 50%);
    background-size: 2px 12px;
    background-repeat: repeat-y;
  }
</style>
