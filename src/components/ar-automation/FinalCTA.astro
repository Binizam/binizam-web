---
import { getLocaleFromPath } from '../../lib/i18n';

const isAr = getLocaleFromPath(Astro.url.pathname) === 'ar';
const copy = isAr ? {
  title: 'هل تريد مناقشة سير عمل الذمم؟',
  text: 'أرسل النسخة المختصرة: ما الذي يتعثر في AR؟ ما الأنظمة المتداخلة؟ وما أول نطاق آمن للبدء؟',
  href: '/ar/contact',
  label: 'تحدّث مع مهندس'
} : {
  title: 'Ready to discuss your AR workflow?',
  text: 'Send us the short version: what AR work is stuck, what systems are involved, and what a good first slice would look like.',
  href: '/contact',
  label: 'Talk to an engineer'
};
---
<section id="final-cta" class="max-w-6xl mx-auto px-6 mb-16 reveal">
  <div class="py-16 flex flex-col items-center justify-center gap-6 text-center">
    <h2 class="text-2xl font-semibold tracking-tight text-primary dark:text-stone-50">{copy.title}</h2>
    <p class="text-sm text-muted dark:text-stone-400 max-w-xl">
      {copy.text}
    </p>
    <a href={copy.href} class="inline-flex items-center justify-center px-8 py-3 text-sm font-semibold text-white bg-amber-600 hover:bg-amber-700 rounded-lg transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 whitespace-nowrap">
      {copy.label}
    </a>
  </div>
</section>
