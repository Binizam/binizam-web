---
const typicalWorkflows = [
  {
    title: "Prioritized collector worklists",
    icon: "solar:sort-from-bottom-to-top-linear",
    items: ["Queues ranked by rules you define (aging, amount, segment, SLA).", "Reason codes + “next action” guidance natively integrated.", "Clear ownership per line item to avoid overlap."]
  },
  {
    title: "Follow-up sequences",
    icon: "solar:alarm-linear",
    items: ["Cadence logic with systematic reminders.", "Pre-defined escalation paths to management.", "Accountability mechanisms to ensure no silent drops."]
  },
  {
    title: "PTP + disputes",
    icon: "solar:hand-shake-linear",
    items: ["Consistent status tracking and required input fields.", "Automated routing to avoid stalling on handoffs.", "Secure sign-offs for sensitive outcome adjustments."]
  },
  {
    title: "Reconciliation queues",
    icon: "solar:layers-minimalistic-linear",
    items: ["“Expected vs actual” mismatches isolated and queued.", "Step-by-step resolution pathways mapped to owners."]
  },
  {
    title: "Manager exceptions + approvals",
    icon: "solar:shield-keyhole-linear",
    items: ["Fast approvals for routine, low-risk cases.", "Tighter systematic control for critical overrides.", "Permanent audit trail for every single decision."]
  }
];
---
<section id="typical-workflows" class="max-w-4xl mx-auto px-6 mb-32 reveal">
  <h2 class="text-2xl md:text-3xl font-semibold tracking-tight text-primary dark:text-stone-50 mb-10 text-center">Typical workflows</h2>
  <div class="space-y-3">
    {typicalWorkflows.map((workflow, index) => (
      <details class="group bg-main dark:bg-stone-950 border border-stone-200 dark:border-stone-800 rounded-2xl open:border-stone-300 dark:open:border-stone-700 overflow-hidden transition-all duration-300 shadow-sm" open={index === 0}>
        <summary class="flex items-center justify-between p-6 cursor-pointer select-none hover:bg-surface/30 dark:hover:bg-stone-800/30 transition-colors outline-none">
          <h3 class="font-semibold text-sm md:text-base text-primary dark:text-stone-100">{workflow.title}</h3>
          <span class="transform transition-transform duration-300 group-open:rotate-180 text-muted">
            <iconify-icon icon="solar:alt-arrow-down-linear" width="20" stroke-width="1.5"></iconify-icon>
          </span>
        </summary>
        <div class="p-6 pt-0 flex flex-col md:flex-row items-center gap-8 border-t border-transparent group-open:border-stone-100 dark:group-open:border-stone-800/50">
          <ul class="space-y-4 flex-1 text-sm text-primary dark:text-stone-300 pt-4 w-full">
            {workflow.items.map(item => (
              <li class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 rounded-full bg-stone-300 dark:bg-stone-600 mt-1.5 flex-shrink-0"></div>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <div class="w-full md:w-48 h-24 bg-surface/50 dark:bg-stone-900/50 rounded-xl flex items-center justify-center border border-stone-200 dark:border-stone-800 mt-4 md:mt-0 flex-shrink-0">
            <iconify-icon icon={workflow.icon} width="28" class="text-stone-400 dark:text-stone-600"></iconify-icon>
          </div>
        </div>
      </details>
    ))}
  </div>
</section>

<style is:global>
  details > summary { list-style: none; }
  details > summary::-webkit-details-marker { display: none; }
  details[open] summary ~ div { animation: slideDown 0.3s ease-in-out; }
  @keyframes slideDown {
    0% { opacity: 0; transform: translateY(-10px); }
    100% { opacity: 1; transform: translateY(0); }
  }
</style>