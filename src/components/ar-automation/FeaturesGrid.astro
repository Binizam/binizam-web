---
const includedFeatures = [
  { icon: "solar:list-check-minimalistic-linear", title: "Prioritized collector worklists", text: "Equip collectors with dynamically ranked queues and clear next actions to maximize focus." },
  { icon: "solar:history-2-linear", title: "Follow-up sequences", text: "Automate cadence logic with embedded reminders and structured escalation paths." },
  { icon: "solar:users-group-two-rounded-linear", title: "PTP and dispute handling", text: "Capture consistent states for promises to pay and disputes, triggering native approvals." },
  { icon: "solar:scale-linear", title: "Reconciliation queues", text: "Surface “out-of-sync” items early, routing exceptions directly to the relevant owners." },
  { icon: "solar:key-minimalistic-square-linear", title: "Manager exceptions", text: "Provide management with simple override tools for sensitive financial actions." },
  { icon: "solar:document-text-linear", title: "Audit trails", text: "Ensure completely traceable outcomes permanently tied to events, logic, and users." }
];
---
<section id="what-it-includes" class="max-w-6xl mx-auto px-6 mb-32 pt-16 reveal border-t border-stone-200/50 dark:border-stone-800/50">
  <h2 class="text-2xl md:text-3xl font-semibold tracking-tight text-primary dark:text-stone-50 mb-10">What it includes</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
    {includedFeatures.map(card => (
      <div class="p-6 rounded-2xl bg-main dark:bg-stone-950 border border-stone-200 dark:border-stone-800 hover:border-amber-600/40 transition-all duration-300 group shadow-sm relative overflow-hidden flex flex-col gap-3">
        <div class="w-10 h-10 rounded-lg bg-surface dark:bg-stone-800 flex items-center justify-center text-muted group-hover:text-amber-600 transition-colors border border-stone-200 dark:border-stone-700">
          <iconify-icon icon={card.icon} width="20" stroke-width="1.5"></iconify-icon>
        </div>
        <h3 class="text-sm font-semibold text-primary dark:text-stone-100">{card.title}</h3>
        <p class="text-sm text-muted dark:text-stone-400 leading-relaxed">{card.text}</p>
      </div>
    ))}
  </div>
</section>