---
import { getLocaleFromPath, type Locale } from '../../lib/i18n';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale || getLocaleFromPath(Astro.url.pathname);
const isAr = locale === 'ar';
const copy = isAr ? {
  heading: 'علامات تدل على احتياجك لهذا النظام',
  painPoints: [
    "يعمل المحصلون من تقارير أعمار الديون المصدرة، سلاسل البريد الإلكتروني، والملاحظات الخاصة بدلًا من قائمة عمل مشتركة.",
    "تعتمد متابعة الرقابة الائتمانية على الانضباط الفردي، مما يجعل تدقيق الفريق شبه مستحيل.",
    "النزاعات، وعود السداد، السدادات الناقصة، والخصومات تفقد مالكها أو تتعطل إلى أجل غير مسمى.",
    "تظهر مشاكل مطابقة المدفوعات، إشعارات السداد، تخصيص المقبوضات، والتسويات متأخرة في الدورة.",
    "لا يستطيع المديرون رؤية الأرصدة الموقوفة مقابل القابلة للتحصيل لعدم تسجيل حالات سير العمل مركزيًا."
  ],
  quickFitTitle: 'فحص ملاءمة سريع:',
  quickFitDesc: '15–20 دقيقة مع مهندس. رد خلال يوم إلى يومي عمل. سنوصي بأول جزء من سير العمل بعد الاستماع لسياق عملك.',
  button: 'تحدّث مع مهندس',
  href: '/ar/contact'
} : {
  heading: 'Signs you need this',
  painPoints: [
    "Collectors work from exported aging reports, inbox threads, and private notes instead of a shared queue.",
    "Credit-control follow-up depends on individual discipline, making team audits nearly impossible.",
    "Disputes, PTP, promise-to-pay dates, short-pays, and deductions lose ownership or stall indefinitely.",
    "Payment matching, remittance handling, receipt allocation, and reconciliation issues surface late in the cycle.",
    "Managers cannot see blocked-vs-collectible balances because workflow states are not captured centrally."
  ],
  quickFitTitle: 'Quick fit check:',
  quickFitDesc: '15–20 minutes with an engineer. Reply in 1–2 business days. We’ll recommend a first workflow slice after hearing your context.',
  button: 'Talk to an engineer',
  href: '/contact'
};
---
<section id="signs-you-need-this" class="max-w-6xl mx-auto px-6 mb-32 reveal" dir={isAr ? 'rtl' : 'ltr'}>
  <div class="bg-surface/30 dark:bg-stone-950 rounded-3xl p-8 md:p-12 border border-stone-200 dark:border-stone-800 shadow-sm relative overflow-hidden">
    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight text-primary dark:text-stone-50 mb-10 relative z-10 text-center md:text-start">{copy.heading}</h2>
    <div class="grid md:grid-cols-2 gap-x-16 gap-y-6 mb-12 relative z-10 text-start">
      {copy.painPoints.map((point, i) => (
        <div class={`flex gap-4 items-start group ${i === copy.painPoints.length - 1 ? 'md:col-span-2' : ''}`}>
          <div class="w-5 h-5 rounded flex items-center justify-center border border-amber-600/30 bg-amber-600/5 mt-0.5 shrink-0 group-hover:border-amber-600/60 transition-colors">
            <iconify-icon icon="solar:close-square-linear" class="text-amber-600" width="14" stroke-width="1.5"></iconify-icon>
          </div>
          <span class="text-primary dark:text-stone-300 text-sm leading-relaxed">{point}</span>
        </div>
      ))}
    </div>
    <div class="bg-main dark:bg-stone-900/80 rounded-2xl p-6 flex flex-col md:flex-row justify-between items-center gap-6 text-center md:text-start border border-stone-200 dark:border-stone-800 shadow-sm relative z-10">
      <div class="text-sm text-muted dark:text-stone-300 leading-relaxed flex-1 text-start">
        <strong class="font-semibold text-primary dark:text-stone-100">{copy.quickFitTitle}</strong> {copy.quickFitDesc}
      </div>
      <a href={copy.href} class="inline-flex flex-shrink-0 items-center justify-center px-6 py-2.5 text-sm font-semibold text-main bg-primary dark:bg-stone-100 dark:text-primary hover:bg-stone-800 dark:hover:bg-white rounded-lg transition-all shadow-sm whitespace-nowrap">
        {copy.button}
      </a>
    </div>
  </div>
</section>
