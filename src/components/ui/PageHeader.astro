---
interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
---
<section class="max-w-6xl mx-auto px-6 mb-20 reveal">
  <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-primary dark:text-stone-50 mb-6">
    {title}
  </h1>
  <p class="text-xl text-stone-600 dark:text-stone-400 font-light max-w-2xl leading-relaxed">
    {description}
  </p>
</section>