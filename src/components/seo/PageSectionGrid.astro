---
import type { PageSection } from '../../data/siteContent';

interface Props {
  section: PageSection;
}

const { section } = Astro.props;
---

<section id={section.id} class="max-w-6xl mx-auto px-6 py-14 border-t border-stone-200/70 dark:border-stone-800/70">
  <div class="grid lg:grid-cols-12 gap-10">
    <div class="lg:col-span-4 max-w-xl">
      <p class="text-xs font-mono uppercase tracking-[0.22em] text-amber-700 dark:text-amber-500 reveal">
        {section.eyebrow}
      </p>
      <h2 class="mt-4 text-2xl md:text-3xl font-semibold tracking-tight text-primary dark:text-stone-50 reveal">
        {section.title}
      </h2>
      <p class="mt-4 text-sm leading-7 text-stone-600 dark:text-stone-400 reveal delay-100">
        {section.intro}
      </p>
      {section.note && (
        <p class="mt-6 text-xs leading-6 text-stone-500 dark:text-stone-500 border-l border-amber-600/30 pl-4 reveal delay-200">
          {section.note}
        </p>
      )}
    </div>

    <div class="lg:col-span-8 grid sm:grid-cols-2 gap-4">
      {section.cards.map((card, index) => (
        <article class={`rounded-3xl border border-stone-200 dark:border-stone-800 bg-white/70 dark:bg-stone-950/60 p-6 shadow-sm hover:border-amber-600/40 transition-all reveal ${index % 2 === 1 ? 'delay-100' : ''}`}>
          <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-stone-200 dark:border-stone-700 bg-surface dark:bg-stone-800 text-amber-700 dark:text-amber-500">
            <iconify-icon icon={card.icon} width="22" stroke-width="1.5"></iconify-icon>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-primary dark:text-stone-100">
            {card.title}
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-stone-600 dark:text-stone-400">
            {card.text}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
