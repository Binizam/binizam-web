---
import type { PageCard } from '../../data/siteContent';

interface Props {
  cards: PageCard[];
}

const { cards } = Astro.props;
---

<section class="max-w-6xl mx-auto px-6 pb-16">
  <div class="grid md:grid-cols-3 gap-4">
    {cards.map((card, index) => (
      <article class={`rounded-3xl border border-stone-200 dark:border-stone-800 bg-white/70 dark:bg-stone-950/60 p-6 shadow-sm reveal ${index === 1 ? 'delay-100' : index === 2 ? 'delay-200' : ''}`}>
        <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-stone-200 dark:border-stone-700 bg-surface dark:bg-stone-800 text-amber-700 dark:text-amber-500">
          <iconify-icon icon={card.icon} width="22" stroke-width="1.5"></iconify-icon>
        </div>
        <h2 class="mt-4 text-base font-semibold text-primary dark:text-stone-100">
          {card.title}
        </h2>
        <p class="mt-3 text-sm leading-relaxed text-stone-600 dark:text-stone-400">
          {card.text}
        </p>
      </article>
    ))}
  </div>
</section>
