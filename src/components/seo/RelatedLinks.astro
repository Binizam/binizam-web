---
import type { RelatedLink } from '../../data/siteContent';

interface Props {
  links: RelatedLink[];
}

const { links } = Astro.props;
---

<section class="max-w-6xl mx-auto px-6 py-16 border-t border-stone-200/70 dark:border-stone-800/70">
  <p class="text-xs font-mono uppercase tracking-[0.22em] text-amber-700 dark:text-amber-500 reveal">
    Related pages
  </p>
  <h2 class="mt-4 text-2xl md:text-3xl font-semibold tracking-tight text-primary dark:text-stone-50 reveal">
    Keep exploring the workflow map
  </h2>

  <div class="mt-10 grid md:grid-cols-3 gap-4">
    {links.map((link, index) => (
      <a
        href={link.href}
        class={`group rounded-3xl border border-stone-200 dark:border-stone-800 bg-white/70 dark:bg-stone-950/60 p-6 shadow-sm hover:border-amber-600/40 hover:-translate-y-1 transition-all reveal ${index === 1 ? 'delay-100' : index === 2 ? 'delay-200' : ''}`}
      >
        <div class="flex items-center justify-between gap-4">
          <p class="text-[0.65rem] font-mono uppercase tracking-[0.24em] text-stone-500 dark:text-stone-500">
            {link.eyebrow}
          </p>
          <div class="flex h-10 w-10 items-center justify-center rounded-2xl border border-stone-200 dark:border-stone-700 bg-surface dark:bg-stone-800 text-amber-700 dark:text-amber-500">
            <iconify-icon icon={link.icon} width="20" stroke-width="1.5"></iconify-icon>
          </div>
        </div>
        <h3 class="mt-4 text-sm font-semibold text-primary dark:text-stone-100 group-hover:text-amber-600 transition-colors">
          {link.label}
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-stone-600 dark:text-stone-400">
          {link.description}
        </p>
      </a>
    ))}
  </div>
</section>
