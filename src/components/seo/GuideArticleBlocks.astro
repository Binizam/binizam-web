---
import type { GuideArticleBlock } from '../../data/siteContent';

interface Props {
  blocks: GuideArticleBlock[];
}

const { blocks } = Astro.props;
---

<section class="max-w-6xl mx-auto px-6 pb-8">
  <div class="grid xl:grid-cols-2 gap-5">
    {blocks.map((block, index) => (
      <article
        id={block.id}
        class={`rounded-[2rem] border border-stone-200 dark:border-stone-800 bg-white/75 dark:bg-stone-950/65 p-7 shadow-sm reveal ${
          index % 2 === 1 ? 'delay-100' : ''
        }`}
      >
        <p class="text-xs font-mono uppercase tracking-[0.22em] text-amber-700 dark:text-amber-500">
          {block.eyebrow}
        </p>

        <h2 class="mt-4 text-2xl font-semibold tracking-tight text-primary dark:text-stone-50">
          {block.title}
        </h2>

        <p class="mt-4 text-sm md:text-base leading-8 text-stone-600 dark:text-stone-400">
          {block.intro}
        </p>

        <div class="mt-7 space-y-3">
          {block.cards.map((card) => (
            <section class="rounded-3xl border border-stone-200/90 dark:border-stone-800 bg-surface/60 dark:bg-stone-900/40 p-5">
              <div class="flex items-start gap-4">
                <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-amber-600/20 bg-amber-600/10 text-amber-700 dark:text-amber-500">
                  <iconify-icon icon={card.icon} width="22" stroke-width="1.5"></iconify-icon>
                </div>

                <div class="min-w-0 flex-1">
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="text-sm font-semibold text-primary dark:text-stone-100">
                      {card.title}
                    </h3>
                    {card.label && (
                      <span class="shrink-0 rounded-full border border-stone-200 dark:border-stone-700 px-2 py-1 text-[0.6rem] font-mono uppercase tracking-[0.18em] text-stone-500 dark:text-stone-500">
                        {card.label}
                      </span>
                    )}
                  </div>

                  <p class="mt-2 text-sm leading-relaxed text-stone-600 dark:text-stone-400">
                    {card.text}
                  </p>
                </div>
              </div>
            </section>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>
