---
interface Props {
  items: Array<{ label: string; href: string }>;
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="max-w-6xl mx-auto px-6 pt-24 sm:pt-28 mb-10 relative z-10">
  <ol class="flex flex-wrap items-center gap-2 text-xs font-mono uppercase tracking-[0.18em] text-stone-500 dark:text-stone-500">
    {items.map((item, index) => (
      <li class="flex items-center gap-2">
        {index > 0 && <span class="text-stone-300 dark:text-stone-700">/</span>}
        {index === items.length - 1 ? (
          <span class="text-amber-700 dark:text-amber-500">{item.label}</span>
        ) : (
          <a href={item.href} class="hover:text-amber-700 dark:hover:text-amber-500 transition-colors">
            {item.label}
          </a>
        )}
      </li>
    ))}
  </ol>
</nav>
