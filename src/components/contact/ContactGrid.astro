---
const quickAnswer = [
  "What process is breaking (and who uses it)",
  "Systems involved (ERP/CRM/bank files/APIs)",
  "Sensitive steps that need approvals or auditability",
  "What “good” looks like (speed, control, traceability)",
];

const bestWith = [
  "AR / finance ops teams with high-volume follow-ups + exceptions",
  "Workflows where approvals and traceability matter",
  "When spreadsheets + inbox are effectively the system",
];

const happensNext = [
  "Reply in 1–2 business days",
  "15–20 min fit check with an engineer",
  "We’ll recommend a first workflow slice after hearing your context (or tell you quickly if it’s not a fit)",
];

const placeholderText = `Process: (e.g., AR follow-up / disputes / reconciliation / approvals)
Where it breaks: (ownership, exceptions, visibility, reporting)
Systems involved: (ERP/CRM/bank files/APIs)
Sensitive steps: (what needs approvals/audit trail)`;
---

<section class="max-w-6xl mx-auto px-6 mb-24 reveal delay-100">
  <div class="grid lg:grid-cols-12 gap-12 lg:gap-8">
    <div class="lg:col-span-5 flex flex-col gap-6">
      <div
        class="bg-surface/50 dark:bg-stone-900/50 rounded-2xl p-8 border border-stone-200 dark:border-stone-800 shadow-sm"
      >
        <h2 class="text-lg font-semibold text-primary dark:text-stone-100 mb-2">
          Quick answer
        </h2>
        <p class="text-sm text-muted dark:text-stone-400 mb-6">
          Send the shortest version of your problem. Two sentences is enough.
        </p>
        <ul class="space-y-4 mb-8">
          {quickAnswer.map((item) => (
            <li class="flex items-start gap-3">
              <div
                class="w-1.5 h-1.5 rounded-full bg-amber-600 mt-1.5 flex-shrink-0"
              >
              </div>
              <span class="text-sm text-stone-600 dark:text-stone-300 leading-relaxed">
                {item}
              </span>
            </li>
          ))}
        </ul>
        <div
          class="flex items-center gap-3 pt-6 border-t border-stone-200 dark:border-stone-800"
        >
          <iconify-icon
            icon="solar:letter-linear"
            class="text-muted"
            width="18"
          ></iconify-icon>
          <span class="text-sm text-stone-500">Prefer email?</span>
          <a
            href="mailto:engineers@binizam.com"
            class="text-sm font-semibold text-primary dark:text-stone-200 hover:text-amber-600 dark:hover:text-amber-500 transition-colors"
          >
            engineers@binizam.com
          </a>
        </div>
      </div>

      <div
        class="bg-surface/50 dark:bg-stone-900/50 rounded-2xl p-8 border border-stone-200 dark:border-stone-800 shadow-sm"
      >
        <h2 class="text-lg font-semibold text-primary dark:text-stone-100 mb-6">
          Who we work best with
        </h2>
        <ul class="space-y-4 mb-6">
          {bestWith.map((item) => (
            <li class="flex items-start gap-3">
              <iconify-icon
                icon="solar:check-circle-linear"
                class="text-amber-600 mt-0.5 flex-shrink-0"
              ></iconify-icon>
              <span class="text-sm text-stone-600 dark:text-stone-300 leading-relaxed">
                {item}
              </span>
            </li>
          ))}
        </ul>
        <p
          class="text-sm text-muted dark:text-stone-500 italic border-t border-stone-200 dark:border-stone-800 pt-6"
        >
          If that’s you, send a short note. If it’s not, we’ll tell you quickly.
        </p>
      </div>
    </div>

    <div class="lg:col-span-7 flex flex-col h-full">
      <div
        class="bg-white dark:bg-stone-950 rounded-2xl p-8 md:p-10 border border-stone-200 dark:border-stone-800 shadow-sm relative overflow-hidden hover:border-amber-600/30 transition-colors duration-300 flex flex-col flex-grow"
      >
        <div
          class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-amber-600/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
        >
        </div>

        <div class="mb-8">
          <h2 class="text-xl font-semibold text-primary dark:text-stone-50 mb-2">
            Send a message
          </h2>
          <p class="text-sm text-muted dark:text-stone-400">
            If you’re not sure what to write, copy/paste the template in the
            message box below.
          </p>
        </div>

        <form class="flex flex-col gap-6 flex-grow" data-contact-form>
          <!-- Honeypot (hidden). Humans won't fill this. -->
          <div
            style="position:absolute; left:-10000px; top:auto; width:1px; height:1px; overflow:hidden;"
            aria-hidden="true"
          >
            <label for="hp">Leave this field empty</label>
            <input id="hp" name="hp" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
              <label for="name" class="text-xs font-semibold text-primary dark:text-stone-300">
                Full Name
                <span class="text-stone-400 dark:text-stone-500 font-normal">(Optional)</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                class="w-full px-4 py-3 rounded-xl bg-surface/50 dark:bg-stone-900/50 border border-stone-200 dark:border-stone-700 text-sm text-primary dark:text-stone-100 focus:outline-none focus:ring-2 focus:ring-amber-600/50 focus:border-amber-600 transition-all"
              />
            </div>

            <div class="flex flex-col gap-2">
              <label for="email" class="text-xs font-semibold text-primary dark:text-stone-300">
                Work Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-xl bg-surface/50 dark:bg-stone-900/50 border border-stone-200 dark:border-stone-700 text-sm text-primary dark:text-stone-100 focus:outline-none focus:ring-2 focus:ring-amber-600/50 focus:border-amber-600 transition-all"
              />
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="company" class="text-xs font-semibold text-primary dark:text-stone-300">
              Company / Organization
              <span class="text-stone-400 dark:text-stone-500 font-normal">(Optional)</span>
            </label>
            <input
              type="text"
              id="company"
              name="company"
              class="w-full px-4 py-3 rounded-xl bg-surface/50 dark:bg-stone-900/50 border border-stone-200 dark:border-stone-700 text-sm text-primary dark:text-stone-100 focus:outline-none focus:ring-2 focus:ring-amber-600/50 focus:border-amber-600 transition-all"
            />
          </div>

          <div class="flex flex-col gap-2 flex-grow">
            <label for="message" class="text-xs font-semibold text-primary dark:text-stone-300">
              Your Message
            </label>
            <textarea
              id="message"
              name="message"
              placeholder={placeholderText}
              required
              class="w-full min-h-[150px] px-4 py-3 rounded-xl bg-surface/50 dark:bg-stone-900/50 border border-stone-200 dark:border-stone-700 text-sm text-primary dark:text-stone-100 placeholder-stone-400/70 dark:placeholder-stone-600 focus:outline-none focus:ring-2 focus:ring-amber-600/50 focus:border-amber-600 transition-all resize-none leading-relaxed flex-grow"
            ></textarea>
          </div>

          <div class="min-h-[20px]">
            <p class="text-xs font-medium hidden" data-contact-status aria-live="polite"></p>
          </div>

          <div class="mt-2 flex justify-end">
            <button
              type="submit"
              data-contact-submit
              class="group inline-flex items-center justify-center gap-2.5 px-8 py-3 text-sm font-semibold text-white bg-amber-600 hover:bg-amber-700 rounded-xl transition-all duration-300 shadow-lg shadow-amber-600/20 hover:shadow-amber-600/40 hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Send message
              <iconify-icon
                icon="solar:arrow-right-linear"
                width="18"
                stroke-width="1.5"
                class="transition-transform duration-300 group-hover:translate-x-1"
              ></iconify-icon>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  function initContactForm() {
    const form = document.querySelector("[data-contact-form]");
    if (!form || form.dataset.bound === "true") return;

    form.dataset.bound = "true";
    const statusEl = form.querySelector("[data-contact-status]");
    const submitBtn = form.querySelector("[data-contact-submit]");
    const originalBtnHtml = submitBtn?.innerHTML;

    const buildFallbackMailto = (payload) => {
      const subject = encodeURIComponent("Binizam workflow inquiry");
      const body = encodeURIComponent(
        [
          `Full Name: ${payload.fullName || "-"}`,
          `Work Email: ${payload.email || "-"}`,
          `Company / Organization: ${payload.company || "-"}`,
          "",
          "Message:",
          payload.message || "-",
          "",
          `Page: ${payload.pageUri}`,
          `Source: ${payload.utmSource || "-"} / ${payload.utmMedium || "-"} / ${payload.utmCampaign || "-"}`
        ].join("\n")
      );

      return `mailto:engineers@binizam.com?subject=${subject}&body=${body}`;
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      // UI Reset
      statusEl?.classList.add("hidden");
      statusEl?.classList.remove(
        "text-green-600",
        "text-red-600",
        "dark:text-green-400",
        "dark:text-red-400"
      );

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Sending...";
      }

      const fd = new FormData(form);
      const params = new URLSearchParams(window.location.search);

      const payload = {
        fullName: String(fd.get("name") || ""),
        email: String(fd.get("email") || ""),
        company: String(fd.get("company") || ""),
        message: String(fd.get("message") || ""),
        honeypot: String(fd.get("hp") || ""),
        pageUri: window.location.href,
        pageName: document.title,
        utmSource: params.get("utm_source") || "",
        utmMedium: params.get("utm_medium") || "",
        utmCampaign: params.get("utm_campaign") || "",
        utmTerm: params.get("utm_term") || "",
        utmContent: params.get("utm_content") || "",
      };

      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        if (!res.ok) {
          if (res.status === 429) throw new Error("RATE_LIMIT");
          if (res.status === 403) throw new Error("FORBIDDEN_ORIGIN");
          if (res.status === 404) throw new Error("CONTACT_API_MISSING");
          throw new Error("SUBMIT_FAILED");
        }

        form.reset();
        statusEl.textContent = "Sent. We'll reply in 1–2 business days.";
        statusEl?.classList.add("text-green-600", "dark:text-green-400");
        statusEl?.classList.remove("hidden");
      } catch (err) {
        let msg = "Something went wrong. Please email engineers@binizam.com.";
        if (err && err.message === "RATE_LIMIT") {
          msg = "Too many attempts. Please wait a minute and try again.";
        } else if (err && err.message === "FORBIDDEN_ORIGIN") {
          msg = "Please refresh the page and try again.";
        } else if (err && err.message === "CONTACT_API_MISSING") {
          window.location.href = buildFallbackMailto(payload);
          msg = "This deployment does not have the form backend yet, so we opened your email app with the message prefilled.";
          statusEl.textContent = msg;
          statusEl?.classList.add("text-green-600", "dark:text-green-400");
          statusEl?.classList.remove("hidden");
          return;
        }

        statusEl.textContent = msg;
        statusEl?.classList.add("text-red-600", "dark:text-red-400");
        statusEl?.classList.remove("hidden");
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          if (originalBtnHtml) submitBtn.innerHTML = originalBtnHtml;
          else submitBtn.textContent = "Send message";
        }
      }
    });
  }

  document.addEventListener("DOMContentLoaded", initContactForm);
  document.addEventListener("astro:page-load", initContactForm);
</script>
