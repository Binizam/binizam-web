---
const quickAnswer = [
  "What process is breaking (and who uses it)",
  "Systems involved (ERP/CRM/bank files/APIs)",
  "Sensitive steps that need approvals or auditability",
  "What “good” looks like (speed, control, traceability)"
];

const bestWith = [
  "AR / finance ops teams with high-volume follow-ups + exceptions",
  "Workflows where approvals and traceability matter",
  "When spreadsheets + inbox are effectively the system"
];

const happensNext = [
  "Reply in 1–2 business days",
  "15–20 min fit check with an engineer",
  "We’ll recommend a first workflow slice after hearing your context (or tell you quickly if it’s not a fit)"
];

const placeholderText = `Process: (e.g., AR follow-up / disputes / reconciliation / approvals)
Where it breaks: (ownership, exceptions, visibility, reporting)
Systems involved: (ERP/CRM/bank files/APIs)
Sensitive steps: (what needs approvals/audit trail)`;
---
<section class="max-w-6xl mx-auto px-6 mb-24 reveal delay-100">
  
  <div class="grid lg:grid-cols-12 gap-12 lg:gap-8">
    
    <div class="lg:col-span-5 flex flex-col gap-6">
      
      <div class="bg-surface/50 dark:bg-stone-900/50 rounded-2xl p-8 border border-stone-200 dark:border-stone-800 shadow-sm">
        <h2 class="text-lg font-semibold text-primary dark:text-stone-100 mb-2">Quick answer</h2>
        <p class="text-sm text-muted dark:text-stone-400 mb-6">Send the shortest version of your problem. Two sentences is enough.</p>
        <ul class="space-y-4 mb-8">
          {quickAnswer.map(item => (
            <li class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 rounded-full bg-amber-600 mt-1.5 flex-shrink-0"></div>
              <span class="text-sm text-stone-600 dark:text-stone-300 leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
        <div class="flex items-center gap-3 pt-6 border-t border-stone-200 dark:border-stone-800">
          <iconify-icon icon="solar:letter-linear" class="text-muted" width="18"></iconify-icon>
          <span class="text-sm text-stone-500">Prefer email?</span>
          <a href="mailto:engineers@binizam.com" class="text-sm font-semibold text-primary dark:text-stone-200 hover:text-amber-600 dark:hover:text-amber-500 transition-colors">
            engineers@binizam.com
          </a>
        </div>
      </div>

      <div class="bg-surface/50 dark:bg-stone-900/50 rounded-2xl p-8 border border-stone-200 dark:border-stone-800 shadow-sm">
        <h2 class="text-lg font-semibold text-primary dark:text-stone-100 mb-6">Who we work best with</h2>
        <ul class="space-y-4 mb-6">
          {bestWith.map(item => (
            <li class="flex items-start gap-3">
              <iconify-icon icon="solar:check-circle-linear" class="text-amber-600 mt-0.5 flex-shrink-0"></iconify-icon>
              <span class="text-sm text-stone-600 dark:text-stone-300 leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
        <p class="text-sm text-muted dark:text-stone-500 italic border-t border-stone-200 dark:border-stone-800 pt-6">
          If that’s you, send a short note. If it’s not, we’ll tell you quickly.
        </p>
      </div>

    </div>

    <div class="lg:col-span-7 flex flex-col h-full">
      <div class="bg-white dark:bg-stone-950 rounded-2xl p-8 md:p-10 border border-stone-200 dark:border-stone-800 shadow-sm relative overflow-hidden hover:border-amber-600/30 transition-colors duration-300 flex flex-col flex-grow">
        
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-amber-600/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-primary dark:text-stone-50 mb-2">Send a message</h2>
          <p class="text-sm text-muted dark:text-stone-400">If you’re not sure what to write, copy/paste the template in the message box below.</p>
        </div>

        <form class="flex flex-col gap-6 flex-grow" action="#" method="POST">
          
          <div class="grid md:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
              <label for="name" class="text-xs font-semibold text-primary dark:text-stone-300">Full Name</label>
              <input type="text" id="name" name="name" required 
                class="w-full px-4 py-3 rounded-xl bg-surface/50 dark:bg-stone-900/50 border border-stone-200 dark:border-stone-700 text-sm text-primary dark:text-stone-100 focus:outline-none focus:ring-2 focus:ring-amber-600/50 focus:border-amber-600 transition-all"
              />
            </div>
            <div class="flex flex-col gap-2">
              <label for="email" class="text-xs font-semibold text-primary dark:text-stone-300">Work Email</label>
              <input type="email" id="email" name="email" required 
                class="w-full px-4 py-3 rounded-xl bg-surface/50 dark:bg-stone-900/50 border border-stone-200 dark:border-stone-700 text-sm text-primary dark:text-stone-100 focus:outline-none focus:ring-2 focus:ring-amber-600/50 focus:border-amber-600 transition-all"
              />
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="company" class="text-xs font-semibold text-primary dark:text-stone-300">
              Company / Organization <span class="text-stone-400 dark:text-stone-500 font-normal">(Optional)</span>
            </label>
            <input type="text" id="company" name="company" 
              class="w-full px-4 py-3 rounded-xl bg-surface/50 dark:bg-stone-900/50 border border-stone-200 dark:border-stone-700 text-sm text-primary dark:text-stone-100 focus:outline-none focus:ring-2 focus:ring-amber-600/50 focus:border-amber-600 transition-all"
            />
          </div>

          <div class="flex flex-col gap-2 flex-grow">
            <label for="message" class="text-xs font-semibold text-primary dark:text-stone-300">Your Message</label>
            <textarea id="message" name="message" placeholder={placeholderText} required
              class="w-full min-h-[150px] px-4 py-3 rounded-xl bg-surface/50 dark:bg-stone-900/50 border border-stone-200 dark:border-stone-700 text-sm text-primary dark:text-stone-100 placeholder-stone-400/70 dark:placeholder-stone-600 focus:outline-none focus:ring-2 focus:ring-amber-600/50 focus:border-amber-600 transition-all resize-none leading-relaxed flex-grow"
            ></textarea>
          </div>

          <div class="mt-2 flex justify-end">
            <button type="submit" class="group inline-flex items-center justify-center gap-2.5 px-8 py-3 text-sm font-semibold text-white bg-amber-600 hover:bg-amber-700 rounded-xl transition-all duration-300 shadow-lg shadow-amber-600/20 hover:shadow-amber-600/40 hover:-translate-y-0.5">
              Send message
              <iconify-icon icon="solar:arrow-right-linear" width="18" stroke-width="1.5" class="transition-transform duration-300 group-hover:translate-x-1"></iconify-icon>
            </button>
          </div>

        </form>
      </div>
    </div>

  </div>

  <div class="mt-8 bg-surface/50 dark:bg-stone-900/50 rounded-2xl p-8 border border-stone-200 dark:border-stone-800 shadow-sm w-full">
    <h2 class="text-lg font-semibold text-primary dark:text-stone-100 mb-6">What happens next</h2>
    
    <ul class="grid md:grid-cols-3 gap-6">
      {happensNext.map((item, i) => (
        <li class="flex items-start gap-4 bg-surface dark:bg-[#1C1917] p-5 rounded-xl border border-stone-200/80 dark:border-stone-800 shadow-sm">
          <div class="w-6 h-6 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-600 flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">
            {i + 1}
          </div>
          <span class="text-sm text-stone-600 dark:text-stone-300 leading-relaxed">{item}</span>
        </li>
      ))}
    </ul>
  </div>

</section>