---
const boundaryPoints = [
  "We typically don’t need health records for workflow automation.",
  "We typically don’t need full payment card data; we keep payment handling out of scope.",
  "We focus on workflow state and the minimal identifiers needed to run and reconcile the process."
];
---
<section class="max-w-4xl mx-auto px-6 mb-8 reveal">
  <div class="bg-surface/50 dark:bg-stone-950 rounded-3xl p-8 md:p-12 border border-stone-200 dark:border-stone-800 shadow-sm relative overflow-hidden">
    <h2 class="text-2xl font-semibold tracking-tight text-primary dark:text-stone-50 mb-4 relative z-10">
      Data boundaries
    </h2>
    <p class="text-sm text-muted dark:text-stone-400 mb-8 relative z-10">
      Early engagements avoid expanding regulated scope:
    </p>
    <ul class="space-y-5 relative z-10">
      {boundaryPoints.map(point => (
        <li class="flex items-start gap-4">
          <div class="w-1.5 h-1.5 rounded-full bg-amber-600 mt-2 flex-shrink-0"></div>
          <span class="text-sm text-primary dark:text-stone-300 leading-relaxed">{point}</span>
        </li>
      ))}
    </ul>
  </div>
</section>