---
const glanceCards = [
  { icon: "solar:users-group-rounded-linear", title: "RBAC and scoped permissions" },
  { icon: "solar:key-minimalistic-linear", title: "SSO support when needed" },
  { icon: "solar:list-check-linear", title: "Audit logs for key actions" },
  { icon: "solar:database-linear", title: "Encryption in transit and at rest" },
  { icon: "solar:minimize-square-minimalistic-linear", title: "Data minimization by design" }
];
---
<section class="max-w-6xl mx-auto px-6 mb-32 reveal border-t border-stone-200/50 dark:border-stone-800/50 pt-16">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {glanceCards.map(card => (
      <div class="p-6 rounded-2xl bg-main dark:bg-stone-950 border border-stone-200 dark:border-stone-800 hover:border-amber-600/40 transition-all duration-300 group shadow-sm flex flex-col gap-4">
        <div class="w-10 h-10 rounded-lg bg-surface dark:bg-stone-800 flex items-center justify-center text-muted group-hover:text-amber-600 transition-colors border border-stone-200 dark:border-stone-700">
          <iconify-icon icon={card.icon} stroke-width="1.5" width="20"></iconify-icon>
        </div>
        <h3 class="text-sm font-semibold text-primary dark:text-stone-100">{card.title}</h3>
      </div>
    ))}
    
    <div class="p-6 rounded-2xl bg-surface/30 dark:bg-stone-900/30 border border-stone-200/50 dark:border-stone-800/50 flex flex-col justify-center shadow-sm md:col-span-2 lg:col-span-1">
      <h3 class="text-sm font-semibold text-primary dark:text-stone-100 mb-1">Practical by default</h3>
      <p class="text-xs text-muted dark:text-stone-400 leading-relaxed">
        We prioritize keeping workflows light and outcomes secure without over-engineering your systems.
      </p>
    </div>
  </div>
</section>