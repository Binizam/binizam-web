---
const steps = [
  {
    number: "1",
    title: "Discovery",
    subtitle: "Clarify the workflow.",
    items: [
      "Map states, handoffs, owners, and exceptions",
      "Identify what currently lives in ERP, spreadsheets, inboxes, or bank/payment files",
      "Define success criteria that operators and managers can verify",
      "Agree the first slice: one queue, one exception path, one reviewer path"
    ]
  },
  {
    number: "2",
    title: "Build",
    subtitle: "Deliver the slice.",
    items: [
      "Implement the queue, views, actions, required fields, and reason codes",
      "Add approvals where outcomes are sensitive",
      "Connect only the systems and fields needed for the workflow",
      "Keep the ERP or source system as the system of record where appropriate"
    ]
  },
  {
    number: "3",
    title: "QA + handover",
    subtitle: "Make it reliable.",
    items: [
      "Test real exceptions: missing data, duplicates, overrides, blocked items, and corrections",
      "Verify permissions and audit logging for key actions",
      "Confirm manager visibility and reporting",
      "Hand over documentation, ownership notes, and runbook basics"
    ]
  }
];
---
<section class="max-w-6xl mx-auto px-6 mb-32 reveal border-t border-stone-200/50 dark:border-stone-800/50 pt-16">
  <h2 class="text-2xl md:text-3xl font-semibold tracking-tight text-primary dark:text-stone-50 mb-16 text-center">
    The delivery model (simple)
  </h2>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-8 relative">
    <div class="hidden lg:block absolute top-6 left-[10%] right-[10%] h-px bg-stone-200 dark:bg-stone-800/50 z-0"></div>
    
    {steps.map(step => (
      <div class="flex flex-col items-center lg:items-start gap-6 relative z-10">
        <div class="w-12 h-12 rounded-full bg-surface dark:bg-stone-800 border border-stone-200 dark:border-stone-700 shadow-sm flex items-center justify-center text-amber-600 font-semibold text-lg">
          {step.number}
        </div>
        <div class="text-center lg:text-left">
          <h3 class="text-lg font-semibold text-primary dark:text-stone-100 mb-1">
            {step.title}
          </h3>
          <p class="text-xs text-muted dark:text-stone-500 mb-4 font-medium uppercase tracking-wider">
            {step.subtitle}
          </p>
          <ul class="space-y-4 text-sm text-muted dark:text-stone-400">
            {step.items.map(item => (
              <li class="flex items-start gap-3 justify-center lg:justify-start">
                <div class="w-1.5 h-1.5 rounded-full bg-amber-600 mt-1.5 flex-shrink-0"></div>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))}
  </div>
</section>
