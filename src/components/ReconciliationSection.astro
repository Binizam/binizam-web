---
import ListItem from './ui/ListItem.astro';
import { getLocaleFromPath, type Locale } from '../lib/i18n';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale || getLocaleFromPath(Astro.url.pathname);
const isAr = locale === 'ar';
const copy = isAr ? {
  heading: 'قوائم مطابقة وتسوية تحت السيطرة.',
  paragraphs: [
    'نبني سير عمل للمطابقة والاستثناءات يقارن ما كان يجب أن يحدث بما حدث فعليًا، ثم يوجّه الفروقات إلى قائمة مراجعة واضحة.',
    'قد يكون ذلك في مطابقة البنك مع الدفتر، مطابقة المدفوعات، تخصيص المقبوضات، استثناءات تشغيلية، أو أي سير عمل يحتاج إلى قرار مضبوط بدل مطاردة الحالة يدويًا.'
  ],
  bullets: [
    'قواعد مطابقة وحدود قابلة للضبط',
    'قوائم استثناءات مع مالك واضح',
    'موافقات للحالات الحساسة',
    'سجل تدقيق للقرارات والتجاوزات والتصحيحات'
  ],
  links: [
    { href: '/ar/capabilities', label: 'استكشف القدرات' },
    { href: '/ar/ar-collections/receivables-reconciliation', label: 'مطابقة وتسوية الذمم المدينة' },
    { href: '/ar/contact', label: 'تحدّث مع مهندس' }
  ],
  visual: {
    title: 'قائمة التسوية',
    status: 'قيد المراجعة',
    bank: 'تغذية البنك',
    ledger: 'دفتر الأستاذ',
    suggested: 'مطابقة مقترحة',
    unmatched: 'غير مطابق',
    needsReview: 'يحتاج مراجعة',
    mismatch: 'فرق في المبلغ',
    auto: 'المطابقة الآلية مفعلة',
    logged: 'كل القرارات مسجلة'
  }
} : {
  heading: 'Reconciliation queues, under control.',
  paragraphs: [
    'We build reconciliation and exception workflows that compare what should have happened with what actually happened, then route mismatches into a clear review queue.',
    'That can mean bank-to-ledger reconciliation, payment matching, receipt allocation, operational exceptions, or any workflow where teams need controlled resolution instead of scattered status chasing.'
  ],
  bullets: [
    'Configurable matching rules and thresholds',
    'Exception review queues with ownership',
    'Approvals where outcomes are sensitive',
    'Audit logs for decisions, overrides, and corrections'
  ],
  links: [
    { href: '/capabilities', label: 'Explore Capabilities' },
    { href: '/ar-collections/receivables-reconciliation', label: 'Explore receivables reconciliation' },
    { href: '/contact', label: 'Talk to an engineer' }
  ],
  visual: {
    title: 'Reconciliation Queue',
    status: 'In review',
    bank: 'Bank feed',
    ledger: 'Ledger',
    suggested: 'Suggested match',
    unmatched: 'Unmatched',
    needsReview: 'Needs review',
    mismatch: 'Amount mismatch',
    auto: 'Auto-match enabled',
    logged: 'All decisions logged'
  }
};
---

<section class="py-20 sm:py-24 relative overflow-hidden" dir={isAr ? 'rtl' : 'ltr'}>
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      
      <div class={`order-1 lg:order-1 flex flex-col items-center lg:items-start lg:text-start text-center`}>
        <div class="w-12 h-12 rounded-lg bg-emerald-50 dark:bg-emerald-900/20 flex items-center justify-center text-emerald-600 dark:text-emerald-400 mb-8 reveal">
          <iconify-icon icon="solar:refresh-circle-linear" stroke-width="1.5" width="24"></iconify-icon>
        </div>
        
        <h2 class="text-3xl font-semibold tracking-tight text-primary dark:text-stone-50 mb-6 reveal delay-100">
          {copy.heading}
        </h2>
        
        <p class="dark:text-stone-400 leading-relaxed text-lg text-stone-600 mb-8 reveal delay-200 max-w-lg">
          {copy.paragraphs[0]}
        </p>
        <p class="dark:text-stone-400 leading-relaxed text-base text-stone-600 mb-8 reveal delay-200 max-w-lg">
          {copy.paragraphs[1]}
        </p>
        
        <div class={`space-y-4 mb-10 reveal delay-300 flex flex-col items-center ${isAr ? 'lg:items-end' : 'lg:items-start'} w-full`}>
          {copy.bullets.map((item) => <ListItem dotColor="amber">{item}</ListItem>)}
        </div>
        
        <div class={`flex flex-wrap items-center justify-center ${isAr ? 'lg:justify-end' : 'lg:justify-start'} gap-x-6 gap-y-3 text-sm font-medium reveal delay-400`}>
          {copy.links.map((link, index) => (
            <>
              <a class="group inline-flex items-center gap-1.5 text-primary dark:text-stone-100 hover:text-amber-600 transition-colors" href={link.href}>
                <span>{link.label}</span>
                <iconify-icon class={`transition-transform ${isAr ? 'group-hover:-translate-x-1' : 'group-hover:translate-x-1'}`} icon={isAr ? 'solar:arrow-left-linear' : 'solar:arrow-right-linear'} width="16"></iconify-icon>
              </a>
              {index < copy.links.length - 1 && <span class="text-stone-300 dark:text-stone-700 hidden sm:block">|</span>}
            </>
          ))}
        </div>
      </div>

      <div class="order-2 lg:order-2 flex justify-center lg:justify-end reveal-right delay-200 min-w-0">
        <div class="w-full max-w-[min(100%,32rem)] dark:bg-stone-950 dark:border-stone-800 bg-[#F8FAFC] border-slate-200 border rounded-2xl p-2 sm:p-4 relative shadow-2xl overflow-hidden">
          <div class="bg-white dark:bg-stone-900 rounded-xl border border-slate-200 dark:border-stone-800 shadow-sm overflow-hidden">
            
            <div class="px-4 sm:px-6 py-4 border-b border-slate-200 dark:border-stone-800 flex items-center justify-between gap-3 bg-white dark:bg-stone-900">
              <h3 class="font-mono text-[10px] font-semibold text-slate-500 dark:text-stone-400 uppercase tracking-widest">{copy.visual.title}</h3>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium bg-slate-100 text-slate-600 dark:bg-stone-800 dark:text-stone-400 border border-slate-200 dark:border-stone-700">{copy.visual.status}</span>
            </div>

            <div class="divide-y divide-slate-100 dark:divide-stone-800 text-sm">
              <div class="grid grid-cols-2 px-4 sm:px-6 py-2 bg-slate-50 dark:bg-stone-950/50 text-[10px] font-bold text-slate-400 dark:text-stone-500 uppercase tracking-widest">
                <div>{copy.visual.bank}</div>
                <div>{copy.visual.ledger}</div>
              </div>

              <div class="grid grid-cols-2 px-4 sm:px-6 py-4 gap-3 sm:gap-4 bg-amber-50/50 dark:bg-amber-900/10 relative group min-w-0">
                <div class="absolute start-0 top-0 bottom-0 w-1 bg-amber-500"></div>
                <div class="min-w-0">
                  <div class="font-medium text-slate-900 dark:text-stone-200 text-xs sm:text-sm" dir="ltr">TXN-8392</div>
                  <div class="text-slate-500 dark:text-stone-500 font-mono text-xs mt-0.5" dir="ltr">$4,250.00</div>
                </div>
                <div class="flex flex-col min-w-0">
                  <div>
                    <div class="font-medium text-slate-900 dark:text-stone-200 text-xs sm:text-sm" dir="ltr">INV-2024-001</div>
                    <div class="text-slate-500 dark:text-stone-500 font-mono text-xs mt-0.5" dir="ltr">$4,250.00</div>
                  </div>
                  <div class="flex items-center gap-1.5 mt-2 text-[10px] text-amber-600 dark:text-amber-500 font-bold uppercase">
                    <iconify-icon icon="solar:check-circle-bold" width="14"></iconify-icon>
                    {copy.visual.suggested}
                  </div>
                </div>
              </div>

              <div class="grid grid-cols-2 px-4 sm:px-6 py-4 gap-3 sm:gap-4 hover:bg-slate-50 dark:hover:bg-stone-800/50 transition-colors min-w-0">
                <div class="min-w-0">
                  <div class="font-medium text-slate-900 dark:text-stone-200 text-xs sm:text-sm" dir="ltr">TXN-8393</div>
                  <div class="text-slate-500 dark:text-stone-500 font-mono text-xs mt-0.5" dir="ltr">$120.50</div>
                </div>
                <div class="flex flex-col justify-between min-w-0">
                  <div class="text-slate-400 dark:text-stone-500 italic font-normal text-xs sm:text-sm">{copy.visual.unmatched}</div>
                  <div class="flex items-center gap-1.5 mt-2 text-[10px] text-slate-500 dark:text-stone-400 font-bold uppercase">
                    <iconify-icon icon="solar:question-circle-linear" width="14"></iconify-icon>
                    {copy.visual.needsReview}
                  </div>
                </div>
              </div>

              <div class="grid grid-cols-2 px-4 sm:px-6 py-4 gap-3 sm:gap-4 hover:bg-slate-50 dark:hover:bg-stone-800/50 transition-colors min-w-0">
                <div class="min-w-0">
                  <div class="font-medium text-slate-900 dark:text-stone-200 text-xs sm:text-sm" dir="ltr">TXN-8394</div>
                  <div class="text-slate-500 dark:text-stone-500 font-mono text-xs mt-0.5" dir="ltr">$850.00</div>
                </div>
                <div class="flex flex-col justify-between min-w-0">
                  <div>
                    <div class="font-medium text-slate-900 dark:text-stone-200 text-xs sm:text-sm" dir="ltr">INV-2024-002</div>
                    <div class="text-red-500 font-mono text-xs mt-0.5" dir="ltr">$870.00</div>
                  </div>
                  <div class="flex items-center gap-1.5 mt-2 text-[10px] text-slate-500 dark:text-stone-400 font-bold uppercase">
                    <iconify-icon icon="solar:danger-triangle-linear" width="14"></iconify-icon>
                    {copy.visual.mismatch}
                  </div>
                </div>
              </div>
            </div>

            <div class="px-4 sm:px-6 py-3 border-t border-slate-200 dark:border-stone-800 bg-slate-50 dark:bg-stone-950/30 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1">
              <span class="text-[10px] font-medium text-slate-500 dark:text-stone-500 uppercase">{copy.visual.auto}</span>
              <span class="text-[10px] text-slate-400 dark:text-stone-600 font-mono">{copy.visual.logged}</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
