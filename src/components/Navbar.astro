---
import Button from './ui/Button.astro';
import { siteNavigation } from '../data/siteContent';
---

<header 
  id="navbar" 
  data-scrolled="false"
  class="fixed top-0 w-full z-40 transition-all duration-300 border-b border-transparent data-[scrolled=true]:bg-[#FFFCF5] data-[scrolled=true]:dark:bg-[#1C1917] data-[scrolled=true]:backdrop-blur-md data-[scrolled=true]:border-stone-800/10 data-[scrolled=true]:dark:border-white/10 data-[scrolled=true]:shadow-sm"
>
  <div class="max-w-6xl mx-auto px-6 h-20 flex items-center justify-between relative">
    
    <a href="/" class="flex items-center group cursor-pointer relative z-50">
      <img 
        alt="Binizam Logo" 
        class="h-7 w-auto block dark:hidden transition-transform duration-300 group-hover:scale-105" 
        src="/logo-light.svg"
      />
      <img 
        alt="Binizam Logo" 
        class="h-7 w-auto hidden dark:block transition-transform duration-300 group-hover:scale-105" 
        src="/logo-dark.svg"
      />
    </a>

    <nav class="hidden md:flex items-center gap-8 relative z-50">
      {siteNavigation.map((item) => (
        item.items ? (
          <div class="relative group/nav">
            <a
              href={item.href}
              class="inline-flex items-center gap-1.5 text-sm font-medium text-stone-600 dark:text-stone-300 hover:text-amber-600 dark:hover:text-amber-500 transition-colors py-2"
            >
              {item.label}
              <iconify-icon icon="solar:alt-arrow-down-linear" width="14" stroke-width="1.5" class="transition-transform duration-300 group-hover/nav:rotate-180"></iconify-icon>
            </a>

            <div class="absolute left-1/2 top-full w-[25rem] -translate-x-1/2 pt-4 opacity-0 pointer-events-none group-hover/nav:opacity-100 group-hover/nav:pointer-events-auto group-focus-within/nav:opacity-100 group-focus-within/nav:pointer-events-auto transition-all duration-200">
              <div class="rounded-[2rem] border border-stone-200 dark:border-stone-800 bg-[#FFFCF5]/95 dark:bg-[#1C1917]/95 backdrop-blur-xl shadow-xl p-3">
                <div class="grid gap-1">
                  {item.items.map((child) => (
                    <a
                      href={child.href}
                      class="group/item flex gap-4 rounded-3xl p-4 hover:bg-white dark:hover:bg-stone-900 transition-colors"
                    >
                      <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-stone-200 dark:border-stone-700 bg-surface dark:bg-stone-800 text-amber-700 dark:text-amber-500">
                        <iconify-icon icon={child.icon} width="20" stroke-width="1.5"></iconify-icon>
                      </div>
                      <div class="min-w-0 flex-1">
                        <p class="text-sm font-semibold text-primary dark:text-stone-100 group-hover/item:text-amber-600 transition-colors">
                          {child.label}
                        </p>
                        <p class="mt-1 text-xs leading-5 text-stone-500 dark:text-stone-400">
                          {child.description}
                        </p>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class="text-sm font-medium text-stone-600 dark:text-stone-300 hover:text-amber-600 dark:hover:text-amber-500 transition-colors"
          >
            {item.label}
          </a>
        )
      ))}
    </nav>

    <div class="flex items-center gap-4 sm:gap-5 relative z-50">
      
      <button 
        id="theme-toggle" 
        type="button" 
        aria-label="Toggle dark mode" 
        class="text-stone-500 dark:text-stone-400 hover:bg-stone-200 dark:hover:bg-stone-800 rounded-full flex items-center justify-center w-9 h-9 border border-stone-300 dark:border-stone-600 transition-colors cursor-pointer"
      >
        <iconify-icon id="theme-toggle-dark-icon" class="hidden" icon="solar:moon-linear" width="18"></iconify-icon>
        <iconify-icon id="theme-toggle-light-icon" class="hidden" icon="solar:sun-linear" width="18"></iconify-icon>
      </button>
      
      <div class="hidden sm:block">
         <Button href="/contact/" variant="primary">Talk to an engineer</Button>
      </div>

      <button 
        id="mobile-menu-open"
        class="flex md:hidden items-center justify-center w-9 h-9 text-stone-600 dark:text-stone-300 hover:bg-stone-200 dark:hover:bg-stone-800 border border-stone-300 dark:border-stone-600 rounded-full bg-transparent transition-all"
        aria-label="Open Menu"
      >
        <iconify-icon icon="solar:hamburger-menu-linear" width="20"></iconify-icon>
      </button>

    </div>
  </div>

  <div 
    id="mobile-menu" 
    class="fixed inset-0 h-screen w-screen bg-[#FFFCF5] dark:bg-[#1C1917] z-[100] translate-x-full transition-transform duration-500 cubic-bezier(0.4, 0, 0.2, 1) md:hidden flex flex-col"
  >
    <div class="h-20 flex items-center justify-end px-6">
      <button 
        id="mobile-menu-close"
        class="flex items-center justify-center w-9 h-9 text-stone-600 dark:text-stone-300 hover:bg-stone-200 dark:hover:bg-stone-800 border border-stone-300 dark:border-stone-600 rounded-full bg-transparent transition-all"
        aria-label="Close Menu"
      >
        <iconify-icon icon="solar:close-circle-linear" width="20"></iconify-icon>
      </button>
    </div>

    <nav class="flex flex-col gap-5 p-8 pt-4 text-lg font-semibold tracking-tight overflow-y-auto">
      {siteNavigation.map((item) => (
        item.items ? (
          <details class="group/mobile border-b border-stone-200 dark:border-stone-800 pb-5">
            <summary class="flex cursor-pointer list-none items-center justify-between text-stone-900 dark:text-stone-100 hover:text-amber-600 transition-colors">
              <span>{item.label}</span>
              <iconify-icon icon="solar:alt-arrow-down-linear" width="20" stroke-width="1.5" class="text-stone-500 group-open/mobile:rotate-180 transition-transform"></iconify-icon>
            </summary>
            <div class="mt-5 grid gap-3">
              <a href={item.href} class="text-sm font-semibold text-amber-700 dark:text-amber-500">
                View all {item.label.toLowerCase()}
              </a>
              {item.items.map((child) => (
                <a href={child.href} class="flex gap-3 rounded-3xl bg-white/60 dark:bg-stone-900/40 p-4">
                  <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-2xl border border-stone-200 dark:border-stone-700 bg-surface dark:bg-stone-800 text-amber-700 dark:text-amber-500">
                    <iconify-icon icon={child.icon} width="18" stroke-width="1.5"></iconify-icon>
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-primary dark:text-stone-100">{child.label}</p>
                    <p class="mt-1 text-xs font-normal leading-5 text-stone-500 dark:text-stone-400">{child.description}</p>
                  </div>
                </a>
              ))}
            </div>
          </details>
        ) : (
          <a href={item.href} class="text-stone-900 dark:text-stone-100 hover:text-amber-600 transition-colors">
            {item.label}
          </a>
        )
      ))}

      <div class="flex flex-col mt-4">
        <Button href="/contact/" variant="primary">Talk to an engineer</Button>
      </div>
    </nav>
  </div>
</header>

<script>
  function updateNavbarScroll() {
    const navbar = document.getElementById('navbar');
    if (navbar) {
      navbar.dataset.scrolled = window.scrollY > 20 ? 'true' : 'false';
    }
  }

  function setupMobileMenu() {
    const openBtn = document.getElementById('mobile-menu-open');
    const closeBtn = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');
    
    if (!openBtn || !closeBtn || !menu || openBtn.dataset.listenerAttached === 'true') return;
    openBtn.dataset.listenerAttached = 'true';

    const openMenu = () => {
      menu.classList.remove('translate-x-full');
      document.body.style.overflow = 'hidden';
    };

    const closeMenu = () => {
      menu.classList.add('translate-x-full');
      document.body.style.overflow = '';
    };

    openBtn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);

    const links = menu.querySelectorAll('a');
    links.forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  }

  function setupThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn || btn.dataset.themeListenerAttached === 'true') return;
    btn.dataset.themeListenerAttached = 'true';

    const darkIcon = document.getElementById('theme-toggle-dark-icon');
    const lightIcon = document.getElementById('theme-toggle-light-icon');

    const updateIcons = () => {
      const isDark = document.documentElement.classList.contains('dark');
      if (isDark) {
        lightIcon?.classList.remove('hidden'); 
        darkIcon?.classList.add('hidden');     
      } else {
        darkIcon?.classList.remove('hidden');  
        lightIcon?.classList.add('hidden');    
      }
    };

    updateIcons();

    btn.addEventListener('click', () => {
      const isCurrentlyDark = document.documentElement.classList.contains('dark');
      if (isCurrentlyDark) {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        document.documentElement.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
      updateIcons();
    });
  }

  window.addEventListener('scroll', updateNavbarScroll, { passive: true });
  
  const init = () => {
    updateNavbarScroll();
    setupThemeToggle();
    setupMobileMenu();
  };

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('astro:page-load', init);
</script>

<style is:global>
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
