---
import Button from './ui/Button.astro';
---

<header 
  id="navbar" 
  data-scrolled="false"
  class="fixed top-0 w-full z-40 transition-all duration-300 border-b border-transparent data-[scrolled=true]:bg-[#FFFCF5]/85 data-[scrolled=true]:dark:bg-[#1C1917]/85 data-[scrolled=true]:backdrop-blur-md data-[scrolled=true]:border-stone-800/10 data-[scrolled=true]:dark:border-white/10 data-[scrolled=true]:shadow-sm"
>
  <div class="max-w-6xl mx-auto px-6 h-20 flex items-center justify-between">
    
    <a href="/" class="flex items-center group cursor-pointer z-50 relative">
      <img 
        alt="Binizam Logo" 
        class="h-7 w-auto block dark:hidden transition-transform duration-300 group-hover:scale-105" 
        src="/logo-light.svg"
      />
      <img 
        alt="Binizam Logo" 
        class="h-7 w-auto hidden dark:block transition-transform duration-300 group-hover:scale-105" 
        src="/logo-dark.svg"
      />
    </a>

    <nav class="hidden md:flex items-center gap-8 relative z-50">
      <a href="/capabilities" class="text-sm font-medium text-stone-600 dark:text-stone-300 hover:text-amber-600 dark:hover:text-amber-500 transition-colors">Capabilities</a>
      <a href="/ar-collections" class="text-sm font-medium text-stone-600 dark:text-stone-300 hover:text-amber-600 dark:hover:text-amber-500 transition-colors">AR Automation</a>
      <a href="/security" class="text-sm font-medium text-stone-600 dark:text-stone-300 hover:text-amber-600 dark:hover:text-amber-500 transition-colors">Security</a>
      <a href="/how-we-work" class="text-sm font-medium text-stone-600 dark:text-stone-300 hover:text-amber-600 dark:hover:text-amber-500 transition-colors">How we work</a>
    </nav>

    <div class="flex items-center gap-5 relative z-50">
      
      <button 
        id="theme-toggle" 
        type="button" 
        aria-label="Toggle dark mode" 
        class="text-stone-500 dark:text-stone-400 hover:bg-stone-200 dark:hover:bg-stone-800 rounded-full flex items-center justify-center w-9 h-9 border border-stone-300 dark:border-stone-600 transition-colors cursor-pointer"
      >
        <iconify-icon id="theme-toggle-dark-icon" class="hidden" icon="solar:moon-linear" width="18"></iconify-icon>
        <iconify-icon id="theme-toggle-light-icon" class="hidden" icon="solar:sun-linear" width="18"></iconify-icon>
      </button>
      
      <div class="hidden sm:block">
         <Button href="/contact" variant="primary">Talk to an engineer</Button>
      </div>

    </div>
  </div>
</header>

<script>
  // 1. Data-Attribute Scroll Logic
  function updateNavbarScroll() {
    const navbar = document.getElementById('navbar');
    if (navbar) {
      navbar.dataset.scrolled = window.scrollY > 20 ? 'true' : 'false';
    }
  }

  // 2. Theme Toggle Logic
  function setupThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    
    // Safety check: Stop if button is missing OR if we already attached the listener
    if (!btn || btn.dataset.listenerAttached === 'true') return;
    
    // Mark it as attached so we don't double-bind it
    btn.dataset.listenerAttached = 'true';

    const darkIcon = document.getElementById('theme-toggle-dark-icon');
    const lightIcon = document.getElementById('theme-toggle-light-icon');

    // Sync icons with initial load state
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      lightIcon?.classList.remove('hidden'); 
      darkIcon?.classList.add('hidden');     
    } else {
      darkIcon?.classList.remove('hidden');  
      lightIcon?.classList.add('hidden');    
    }

    // Handle the actual click event
    btn.addEventListener('click', () => {
      const isCurrentlyDark = document.documentElement.classList.contains('dark');
      
      if (isCurrentlyDark) {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('theme', 'light');
        lightIcon?.classList.add('hidden');    // Hide Sun
        darkIcon?.classList.remove('hidden');  // Show Moon
      } else {
        document.documentElement.classList.add('dark');
        localStorage.setItem('theme', 'dark');
        darkIcon?.classList.add('hidden');     // Hide Moon
        lightIcon?.classList.remove('hidden'); // Show Sun
      }
    });
  }

  // Run on load and scroll
  window.addEventListener('scroll', updateNavbarScroll, { passive: true });
  
  document.addEventListener('DOMContentLoaded', () => {
    updateNavbarScroll();
    setupThemeToggle();
  });
  
  document.addEventListener('astro:page-load', () => {
    updateNavbarScroll();
    setupThemeToggle();
  });
</script>