---
import Button from './ui/Button.astro';
import { getLocalizedPath, getLocaleFromPath, type Locale } from '../lib/i18n';

interface Props {
  locale?: Locale;
}

const { locale: localeProp } = Astro.props;
const locale = localeProp || getLocaleFromPath(Astro.url.pathname);
const isAr = locale === 'ar';
const currentPath = Astro.url.pathname;
const homeHref = isAr ? '/ar' : '/';
const labels = isAr ? {
  capabilities: 'القدرات',
  arCollections: 'تحصيل الذمم المدينة',
  security: 'الأمان',
  howWeWork: 'كيف نعمل',
  contact: 'تحدّث مع مهندس',
  toggleTheme: 'تبديل الوضع الداكن',
  openMenu: 'فتح القائمة',
  closeMenu: 'إغلاق القائمة'
} : {
  capabilities: 'Capabilities',
  arCollections: 'AR Collections',
  security: 'Security',
  howWeWork: 'How we work',
  contact: 'Talk to an engineer',
  toggleTheme: 'Toggle dark mode',
  openMenu: 'Open Menu',
  closeMenu: 'Close Menu'
};

const links = [
  { href: isAr ? '/ar/capabilities' : '/capabilities', label: labels.capabilities },
  { href: isAr ? '/ar/ar-collections' : '/ar-collections', label: labels.arCollections },
  { href: isAr ? '/ar/security' : '/security', label: labels.security },
  { href: isAr ? '/ar/how-we-work' : '/how-we-work', label: labels.howWeWork }
];

const contactHref = isAr ? '/ar/contact' : '/contact';
const englishHref = getLocalizedPath(currentPath, 'en');
const arabicHref = getLocalizedPath(currentPath, 'ar');
---

<header 
  id="navbar" 
  data-scrolled="false"
  class="fixed top-0 w-full z-40 transition-all duration-300 border-b border-transparent data-[scrolled=true]:bg-[#FFFCF5] data-[scrolled=true]:dark:bg-[#1C1917] data-[scrolled=true]:backdrop-blur-md data-[scrolled=true]:border-stone-800/10 data-[scrolled=true]:dark:border-white/10 data-[scrolled=true]:shadow-sm"
>
  <div class="w-full px-5 sm:px-6 h-20 flex items-center justify-between gap-4 relative lg:max-w-6xl lg:mx-auto" dir={isAr ? 'rtl' : 'ltr'}>
    
    <a href={homeHref} class="flex items-center group cursor-pointer z-50 shrink-0">
      {isAr ? (
        <>
          <img
            alt="شعار بنظام"
            class="h-8 w-[96px] block dark:hidden transition-transform duration-300 group-hover:scale-105"
            src="/logo-ar-light.svg"
          />
          <img
            alt="شعار بنظام"
            class="h-8 w-[96px] hidden dark:block transition-transform duration-300 group-hover:scale-105"
            src="/logo-ar-dark.svg"
          />
        </>
      ) : (
        <>
          <img
            alt="Binizam Logo"
            class="h-7 w-[107px] block dark:hidden transition-transform duration-300 group-hover:scale-105"
            src="/logo-light.svg"
          />
          <img
            alt="Binizam Logo"
            class="h-7 w-[107px] hidden dark:block transition-transform duration-300 group-hover:scale-105"
            src="/logo-dark.svg"
          />
        </>
      )}
    </a>

    <nav class="hidden lg:flex items-center gap-5 xl:gap-8 relative z-50 min-w-0">
      {links.map((link) => (
        <a href={link.href} class="text-sm font-medium text-stone-600 dark:text-stone-300 hover:text-amber-600 dark:hover:text-amber-500 transition-colors whitespace-nowrap">{link.label}</a>
      ))}
    </nav>

    <div class="flex items-center justify-end gap-3 sm:gap-4 z-50 shrink-0">
      <div class="hidden lg:flex items-center gap-2 text-xs font-semibold text-stone-500 dark:text-stone-400 whitespace-nowrap">
        <a class={`hover:text-amber-600 transition-colors ${!isAr ? 'text-primary dark:text-stone-100' : ''}`} href={englishHref} hreflang="en">English</a>
        <span class="text-stone-300 dark:text-stone-700">/</span>
        <a class={`hover:text-amber-600 transition-colors ${isAr ? 'text-primary dark:text-stone-100' : ''}`} href={arabicHref} hreflang="ar">العربية</a>
      </div>
      
      <button 
        id="theme-toggle" 
        type="button" 
        aria-label={labels.toggleTheme}
        class="text-stone-500 dark:text-stone-400 hover:bg-stone-200 dark:hover:bg-stone-800 rounded-full flex items-center justify-center w-9 h-9 border border-stone-300 dark:border-stone-600 transition-colors cursor-pointer"
      >
        <iconify-icon id="theme-toggle-dark-icon" class="hidden" icon="solar:moon-linear" width="18"></iconify-icon>
        <iconify-icon id="theme-toggle-light-icon" class="hidden" icon="solar:sun-linear" width="18"></iconify-icon>
      </button>
      
      <div class="hidden lg:block">
         <Button href={contactHref} variant="primary" class="shrink-0">{labels.contact}</Button>
      </div>

      <button 
        id="mobile-menu-open"
        class="flex lg:hidden items-center justify-center w-9 h-9 text-stone-600 dark:text-stone-300 hover:bg-stone-200 dark:hover:bg-stone-800 border border-stone-300 dark:border-stone-600 rounded-full bg-transparent transition-all"
        aria-label={labels.openMenu}
      >
        <iconify-icon icon="solar:hamburger-menu-linear" width="20"></iconify-icon>
      </button>

    </div>
  </div>

  <div 
    id="mobile-menu" 
    class="fixed inset-0 h-screen w-full bg-[#FFFCF5] dark:bg-[#1C1917] z-[100] opacity-0 invisible pointer-events-none transition-opacity duration-200 lg:hidden flex flex-col"
    dir={isAr ? 'rtl' : 'ltr'}
  >
    <div class="h-20 flex items-center justify-between gap-4 px-6 border-b border-stone-200/60 dark:border-stone-800/70">
      <a href={homeHref} class="flex items-center group cursor-pointer min-w-0">
        {isAr ? (
          <>
            <img
              alt="شعار بنظام"
              class="h-8 w-[96px] block dark:hidden"
              src="/logo-ar-light.svg"
            />
            <img
              alt="شعار بنظام"
              class="h-8 w-[96px] hidden dark:block"
              src="/logo-ar-dark.svg"
            />
          </>
        ) : (
          <>
            <img
              alt="Binizam Logo"
              class="h-7 w-[107px] block dark:hidden"
              src="/logo-light.svg"
            />
            <img
              alt="Binizam Logo"
              class="h-7 w-[107px] hidden dark:block"
              src="/logo-dark.svg"
            />
          </>
        )}
      </a>
      <button 
        id="mobile-menu-close"
        class="flex items-center justify-center w-9 h-9 text-stone-600 dark:text-stone-300 hover:bg-stone-200 dark:hover:bg-stone-800 border border-stone-300 dark:border-stone-600 rounded-full bg-transparent transition-all"
        aria-label={labels.closeMenu}
      >
        <iconify-icon icon="solar:close-circle-linear" width="20"></iconify-icon>
      </button>
    </div>

    <nav class="flex flex-col items-start gap-8 p-8 pt-8 text-lg font-semibold tracking-tight text-start">
      {links.map((link) => (
        <a href={link.href} class="text-stone-900 dark:text-stone-100 hover:text-amber-600 transition-colors">{link.label}</a>
      ))}
      <div class="flex items-center gap-3 text-sm font-semibold text-stone-500 dark:text-stone-400">
        <a class={`hover:text-amber-600 transition-colors ${!isAr ? 'text-primary dark:text-stone-100' : ''}`} href={englishHref} hreflang="en">English</a>
        <span class="text-stone-300 dark:text-stone-700">/</span>
        <a class={`hover:text-amber-600 transition-colors ${isAr ? 'text-primary dark:text-stone-100' : ''}`} href={arabicHref} hreflang="ar">العربية</a>
      </div>
      
      <div class="flex flex-col mt-4">
        <Button href={contactHref} variant="primary">{labels.contact}</Button>
      </div>
    </nav>
  </div>
</header>

<script>
  function updateNavbarScroll() {
    const navbar = document.getElementById('navbar');
    if (navbar) {
      navbar.dataset.scrolled = window.scrollY > 20 ? 'true' : 'false';
    }
  }

  function setupMobileMenu() {
    const openBtn = document.getElementById('mobile-menu-open');
    const closeBtn = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');
    
    if (!openBtn || !closeBtn || !menu || openBtn.dataset.listenerAttached === 'true') return;
    openBtn.dataset.listenerAttached = 'true';

    const openMenu = () => {
      menu.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
      menu.classList.add('opacity-100', 'visible', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';
    };

    const closeMenu = () => {
      menu.classList.add('opacity-0', 'invisible', 'pointer-events-none');
      menu.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
      document.body.style.overflow = '';
    };

    openBtn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);

    const links = menu.querySelectorAll('a');
    links.forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  }

  function setupThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn || btn.dataset.themeListenerAttached === 'true') return;
    btn.dataset.themeListenerAttached = 'true';

    const darkIcon = document.getElementById('theme-toggle-dark-icon');
    const lightIcon = document.getElementById('theme-toggle-light-icon');

    const updateIcons = () => {
      const isDark = document.documentElement.classList.contains('dark');
      if (isDark) {
        lightIcon?.classList.remove('hidden'); 
        darkIcon?.classList.add('hidden');     
      } else {
        darkIcon?.classList.remove('hidden');  
        lightIcon?.classList.add('hidden');    
      }
    };

    updateIcons();

    btn.addEventListener('click', () => {
      const isCurrentlyDark = document.documentElement.classList.contains('dark');
      if (isCurrentlyDark) {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        document.documentElement.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
      updateIcons();
    });
  }

  window.addEventListener('scroll', updateNavbarScroll, { passive: true });
  
  const init = () => {
    updateNavbarScroll();
    setupThemeToggle();
    setupMobileMenu();
  };

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('astro:page-load', init);
</script>
