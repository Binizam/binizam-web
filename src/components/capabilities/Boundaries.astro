---
const boundaries = [
  "Not an ERP replacement",
  "Not a payments provider",
  "When an ERP is involved, we add a controlled, auditable workflow layer on top of your ERP."
];
---
<section class="max-w-6xl mx-auto px-6 mb-24 reveal">
  <div class="rounded-xl border border-stone-300 dark:border-stone-700 p-8">
    <div class="grid md:grid-cols-12 gap-8 items-start">
      <div class="md:col-span-4">
        <h2 class="text-xl font-semibold tracking-tight text-primary dark:text-stone-50">
          Boundaries
        </h2>
      </div>
      <div class="md:col-span-8">
        <ul class="space-y-4">
          {boundaries.map(boundary => (
            <li class="flex items-start gap-4 text-stone-600 dark:text-stone-300">
              <div class="mt-2 w-1.5 h-1.5 rounded-full bg-stone-400 flex-shrink-0"></div>
              <span>{boundary}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>