---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import ArabicParityPage from '../../../components/ar/ArabicParityPage.astro';
import { arPages } from '../../../content/arabicPages';
import { makeServiceStructuredData } from '../../../lib/schema';

const page = arPages.logistics;
const site = Astro.site || new URL('https://binizam.com');
const structuredData = makeServiceStructuredData({
  site,
  path: '/ar/ar-collections/logistics-3pl-uae#service',
  name: 'أتمتة الذمم لشركات اللوجستيات و3PL في الإمارات',
  serviceType: 'تنفيذ الذمم وسير عمل التحصيل',
  description: page.seo.description,
  areaServed: 'United Arab Emirates',
  audience: 'شركات اللوجستيات و3PL في الإمارات',
  inLanguage: 'ar'
});
---

<Layout title={page.seo.title} description={page.seo.description} structuredData={structuredData} lang="ar">
  <Navbar locale="ar" />
  <ArabicParityPage page={page} />
  <Footer locale="ar" />
</Layout>
