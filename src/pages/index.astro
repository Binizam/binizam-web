---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import FeatureCard from '../components/ui/FeatureCard.astro';
import ListItem from '../components/ui/ListItem.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import ReconciliationSection from '../components/ReconciliationSection.astro';
import FAQAccordion from '../components/seo/FAQAccordion.astro';

// SEO Constants
const seo = {
  title: "Accounts Receivable Automation for GCC Finance Teams | Binizam",
  description: "Accounts receivable automation for GCC finance teams: AR collections, cash application, dispute workflows, reconciliation, Retool-first UIs, and ERP integration."
};

const homeFaqs = [
  {
    q: 'What does Binizam build for AR teams?',
    a: 'Binizam builds collector worklists, dispute/PTP workflows, cash-application exception queues, and ERP-connected reconciliation layers so finance teams work from one controlled operating model.'
  },
  {
    q: 'Does Binizam replace our ERP or payment provider?',
    a: 'No. The ERP and payment systems stay authoritative. Binizam builds the workflow and operator layer around them with approvals, audit logs, and exception routing.'
  },
  {
    q: 'Can implementation start with one workflow only?',
    a: 'Yes. A practical first scope is one collections queue, one reconciliation exception flow, or one country/entity team before expanding to the broader AR suite.'
  }
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homeFaqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.a
    }
  }))
};
---

<Layout title={seo.title} description={seo.description} structuredData={structuredData}>
  <div class="absolute top-0 inset-x-0 h-screen pointer-events-none z-0 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-main dark:to-[#1C1917] z-10"></div>
    <div class="absolute inset-0 [mask-image:radial-gradient(ellipse_at_center_top,black_50%,transparent_100%)] z-0">
      <div class="beam-v left-[calc(50%-20px)]" style="animation: beam-vert 23s infinite ease-in 2s;"></div>
      <div class="beam-v left-[calc(50%-140px)]" style="animation: beam-vert 37s infinite ease-in 10s;"></div>
      <div class="beam-v left-[calc(50%+140px)]" style="animation: beam-vert 29s infinite ease-in 5s;"></div>
      <div class="beam-v left-[calc(50%-300px)] hidden md:block" style="animation: beam-vert 41s infinite ease-in 15s;"></div>
      <div class="beam-v left-[calc(50%+300px)] hidden md:block" style="animation: beam-vert 31s infinite ease-in 0s;"></div>
      <div class="beam-h top-[80px]" style="animation: beam-horz 25s infinite ease-in 4s;"></div>
      <div class="beam-h top-[240px]" style="animation: beam-horz 35s infinite ease-in 8s;"></div>
      <div class="beam-h top-[400px]" style="animation: beam-horz 45s infinite ease-in 18s;"></div>
      <div class="beam-h top-[600px] hidden md:block" style="animation: beam-horz 55s infinite ease-in 1s;"></div>
    </div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_30%,rgba(180,83,9,0.02),transparent_60%)]"></div>
  </div>

  <a class="hidden fixed bottom-8 right-8 z-50 flex items-center justify-center w-14 h-14 rounded-full bg-amber-600 hover:bg-amber-700 text-white shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group reveal delay-500" href="/contact/">
    <iconify-icon height="28" icon="solar:chat-round-dots-linear" stroke-width="1.5" width="28"></iconify-icon>
    <div class="absolute right-full mr-4 px-3 py-1 bg-primary text-main text-xs font-medium rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">
      Talk to an engineer
    </div>
  </a>

  <Navbar />

  <main class="z-10 relative flex-grow flex flex-col">
    
    <Hero />

    <section class="pt-24 pb-8">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-12 gap-12">
          <div class="md:col-span-4">
             <SectionHeader title="What Binizam does" />
          </div>
          <div class="md:col-span-8 space-y-10">
            <p class="text-xl text-primary dark:text-stone-300 font-light leading-relaxed reveal delay-100">
              We turn AR follow-up, dispute routing, cash-application exceptions, and reconciliation handoffs into one controlled workflow layer so finance teams stop chasing status across spreadsheets, inboxes, and ERP screens.
            </p>
            <div class="rounded-3xl border border-amber-600/20 bg-white/70 dark:bg-stone-950/60 p-6 shadow-sm reveal delay-100">
              <p class="text-xs font-mono uppercase tracking-[0.24em] text-stone-500 dark:text-stone-500">
                Direct answer
              </p>
              <p class="mt-3 text-sm md:text-base leading-7 text-primary dark:text-stone-200">
                Binizam is an AR workflow implementation partner for GCC finance teams: we build collections, cash application, dispute, and reconciliation operating layers around your ERP so users have one queue, one approval path, and one auditable state trail.
              </p>
            </div>
            <div class="grid sm:grid-cols-2 gap-y-6 gap-x-8">
              <ListItem icon="solar:checklist-minimalistic-linear" delay="delay-200">
                Prioritized worklists/queues with clear next actions
              </ListItem>
              <ListItem icon="solar:git-branch-linear" delay="delay-300">
                Approvals + exception handling for sensitive steps
              </ListItem>
              <ListItem icon="solar:bolt-linear" delay="delay-200">
                Automation (reminders, escalations, scheduled jobs)
              </ListItem>
              <ListItem icon="solar:link-circle-linear" delay="delay-300">
                Integrations + reconciliation checks so systems stay aligned
              </ListItem>
              <ListItem icon="solar:clock-circle-linear" delay="delay-400" class="sm:col-span-2">
                Workflow-state reporting and audit trails tied to real events
              </ListItem>
            </div>
            <div class="pt-6 border-t border-primary/10 dark:border-stone-800 reveal delay-500">
              <p class="text-sm text-stone-500 mb-4">Retool-first for internal operator UIs, ERP-connected by design, and built to preserve system-of-record boundaries.</p>
              <div class="flex items-center gap-6 text-sm font-medium">
                <span class="text-stone-500/60">Learn more:</span>
                <a class="text-primary dark:text-stone-200 hover:text-amber-600 transition-colors" href="/solutions/">Solutions</a>
                <a class="text-primary dark:text-stone-200 hover:text-amber-600 transition-colors" href="/guides/">Guides</a>
                <a class="text-primary dark:text-stone-200 hover:text-amber-600 transition-colors" href="/security/">Security</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <ReconciliationSection />

    <section class="py-12 max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <FeatureCard title="Control without chaos" icon="solar:shield-check-linear">
          <p>Queues, approvals, and exceptions—built to match how work actually happens.</p>
        </FeatureCard>
        
        <FeatureCard title="Integration-ready by default" icon="solar:plug-circle-linear" delay="delay-100">
          <p>We connect the systems you already run and add reconciliation so failures don't hide quietly.</p>
        </FeatureCard>
        
        <FeatureCard title="Engineer-to-engineer delivery" icon="solar:code-square-linear" delay="delay-200">
          <p class="mb-6">Direct access to engineers, tight review loops, and clear handover documentation.</p>
          <a class="inline-flex items-center text-xs font-mono font-medium text-amber-600 hover:text-amber-700 mt-auto" href="/how-we-work/">
            See: How we work
            <iconify-icon class="ml-1" icon="solar:arrow-right-linear" stroke-width="1.5"></iconify-icon>
          </a>
        </FeatureCard>
      </div>
    </section>

    <section class="py-12 max-w-6xl mx-auto px-6 space-y-8">
      <SectionHeader title="Common starting points" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="relative p-8 rounded-xl border border-amber-600/20 bg-white dark:bg-stone-900 hover:bg-surface dark:hover:bg-stone-800/50 transition-colors group reveal delay-100">
          <div class="absolute top-4 right-4">
            <span class="inline-flex items-center px-2.5 py-1 rounded text-xs font-bold bg-amber-600/10 text-amber-600 uppercase tracking-wider scale-90">Most Common</span>
          </div>
          <h3 class="text-xl font-semibold mb-3 text-primary dark:text-stone-50">AR collections automation</h3>
          <p class="text-stone-500 dark:text-stone-400 text-sm mb-8 leading-relaxed">Collector worklists, follow-ups, disputes/PTP, reconciliation queues, manager exceptions, audit trails.</p>
          <a class="inline-flex items-center text-sm font-semibold text-amber-600 hover:text-amber-700 group-hover:translate-x-1 transition-transform" href="/solutions/ar-collections-automation/">
            <iconify-icon class="mr-2" icon="solar:arrow-right-linear" stroke-width="1.5"></iconify-icon>
            AR Collections Automation
          </a>
        </div>
        <div class="p-8 rounded-xl bg-surface dark:bg-stone-800/30 hover:bg-surface/80 dark:hover:bg-stone-800/60 transition-colors group reveal delay-200">
          <h3 class="text-xl font-semibold mb-3 text-primary dark:text-stone-50">Cash application + reconciliation</h3>
          <p class="text-stone-500 dark:text-stone-400 text-sm mb-8 leading-relaxed">Payment matching, short-pay exceptions, “expected vs actual” routing, and controlled ERP handoff.</p>
          <a class="inline-flex items-center text-sm font-semibold text-primary dark:text-stone-200 group-hover:text-amber-600 transition-colors" href="/solutions/payment-reconciliation-automation/">
            <iconify-icon class="mr-2" icon="solar:arrow-right-linear" stroke-width="1.5"></iconify-icon>
            Payment Reconciliation Automation
          </a>
        </div>
        <div class="p-8 rounded-xl bg-surface dark:bg-stone-800/30 hover:bg-surface/80 dark:hover:bg-stone-800/60 transition-colors group reveal delay-300 md:col-span-2">
          <h3 class="text-xl font-semibold mb-3 text-primary dark:text-stone-50">Educational guides for AR and DSO</h3>
          <p class="text-stone-500 dark:text-stone-400 text-sm mb-8 leading-relaxed">Short, direct-answer guides for what AR automation means, how to reduce DSO in GCC, and how cash application and collections workflows should be structured.</p>
          <a class="inline-flex items-center text-sm font-semibold text-primary dark:text-stone-200 group-hover:text-amber-600 transition-colors" href="/guides/">
            <iconify-icon class="mr-2" icon="solar:arrow-right-linear" stroke-width="1.5"></iconify-icon>
            Explore Guides
          </a>
        </div>
      </div>
    </section>

    <section class="py-12 max-w-6xl mx-auto px-6 border-t border-primary/5 dark:border-white/5">
        <div class="grid md:grid-cols-12 gap-12">
            <div class="md:col-span-4">
                <SectionHeader title="What you'll get" />
            </div>
            <div class="md:col-span-8">
                <p class="text-stone-500 dark:text-stone-400 mb-8">You’ll receive concrete artifacts you can review and keep:</p>
                <div class="grid sm:grid-cols-2 gap-4">
                    {[
                        "Workflow map (states, handoffs, exceptions)",
                        "Queue definitions (priority, next actions)",
                        "Approval points + audit events list",
                        "Integration plan (least-privilege posture)",
                        "Handover docs + runbook basics"
                    ].map((item) => (
                        <div class="flex items-start gap-3 p-4 rounded-lg bg-white/50 dark:bg-stone-900/50 border border-stone-200/50 dark:border-stone-800/50 text-sm reveal">
                            <iconify-icon class="text-amber-600 mt-0.5" icon="solar:file-text-bold" width="16"></iconify-icon>
                            <span class="text-primary dark:text-stone-300">{item}</span>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <section class="py-12 max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12">
        <div class="space-y-6">
          <SectionHeader title="Built with enterprise expectations" />
          <div class="space-y-3 pl-1">
            <ListItem dotColor="primary">RBAC and scoped permissions</ListItem>
            <ListItem dotColor="primary">SSO support when needed</ListItem>
            <ListItem dotColor="primary">Comprehensive audit logging</ListItem>
          </div>
        </div>
        <div class="space-y-6">
          <SectionHeader title="What we don't do" />
          <div class="space-y-3 pl-1 text-sm">
            <ListItem dotColor="red">We don't replace your ERP or CRM.</ListItem>
            <ListItem dotColor="red">We don't build customer-facing mobile apps.</ListItem>
            <ListItem dotColor="red">We don't do generic IT support.</ListItem>
          </div>
        </div>
      </div>
    </section>

    <FAQAccordion faqs={homeFaqs} />

  </main>

  <Footer />
</Layout>
