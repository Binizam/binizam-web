---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/ui/Button.astro';

import PageHeader from '../components/capabilities/PageHeader.astro';
import QuickAnswer from '../components/capabilities/QuickAnswer.astro';
import WhatWeDeliver from '../components/capabilities/WhatWeDeliver.astro';
import AIWorkflows from '../components/capabilities/AIWorkflows.astro';
import Boundaries from '../components/capabilities/Boundaries.astro';
import PageBottomCTA from '../components/capabilities/PageBottomCTA.astro';

// SEO constants
const seo = {
  title: "Internal Workflow Automation Capabilities | Binizam",
  description: "Explore Binizam’s capabilities: Retool-first internal apps, workflow queues, approvals, integrations, reconciliation, audit trails, and automation above your ERP."
};

const capabilityLinks = [
  {
    title: "AR Collections",
    text: "A governed receivables execution workflow above your ERP: aging-based worklists, credit-control follow-up, disputes/PTP tracking, payment matching, reconciliation queues, manager exceptions, and audit trails.",
    href: "/ar-collections",
    cta: "Explore AR Collections"
  },
  {
    title: "Workflow layer above ERP",
    text: "A controlled execution layer for teams that already have ERP but still need queues, approvals, exception handling, reconciliation checks, and manager visibility.",
    href: "/capabilities/workflow-layer-above-erp",
    cta: "Explore Workflow Layer Above ERP"
  },
  {
    title: "Reconciliation and exception workflows",
    text: "Queues for mismatches, out-of-sync records, payment allocation issues, approvals, and operational exceptions that need traceable resolution.",
    href: "/ar-collections/receivables-reconciliation",
    cta: "Explore Receivables Reconciliation"
  }
];

const relatedCapabilities = [
  {
    title: "Internal tools development for GCC teams",
    text: "Custom internal tools, Retool-first apps, admin panels, dashboards, workflow queues, approvals, integrations, and audit trails for finance and operations teams.",
    href: "/capabilities/internal-tools-development-gcc",
    cta: "Explore internal tool development"
  },
  {
    title: "Retool development for internal tools",
    text: "Retool apps and workflow interfaces for GCC teams that need fast, governed internal tools connected to existing systems.",
    href: "/capabilities/retool-development-gcc",
    cta: "Explore Retool development"
  }
];
---

<Layout title={seo.title} description={seo.description}>
  <Navbar />

  <main class="z-10 relative flex-grow pt-32 pb-24">

    <PageHeader
      title="Capabilities for governed internal workflow systems"
      description="Binizam builds internal workflow systems for finance and operations teams that need controlled execution across ERP, bank files, spreadsheets, inboxes, APIs, and internal tools."
    >
      <p>We are not trying to replace your core systems. We build the workflow layer around them: queues, approvals, exception handling, reconciliation checks, reporting, and audit trails.</p>
      <p>Retool-first for internal operator UIs, with integrations and workflow state anchored in your stack.</p>
      <div class="flex flex-col sm:flex-row gap-4 pt-3">
        <Button href="/contact">Talk to an engineer</Button>
        <Button href="/ar-collections" variant="secondary">Explore AR collections</Button>
      </div>
    </PageHeader>

    <WhatWeDeliver />
    <QuickAnswer />

    <section class="max-w-6xl mx-auto px-6 mb-24 reveal">
      <h2 class="text-2xl font-semibold tracking-tight text-primary dark:text-stone-50 mb-8">Related capabilities</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {relatedCapabilities.map(link => (
          <a href={link.href} class="group rounded-xl border border-stone-200 dark:border-stone-800 bg-surface/50 dark:bg-stone-900/40 p-6 hover:border-amber-600/40 transition-colors">
            <h2 class="text-base font-semibold text-primary dark:text-stone-100 mb-3 group-hover:text-amber-600 transition-colors">{link.title}</h2>
            <p class="text-sm text-muted dark:text-stone-400 leading-relaxed mb-6">{link.text}</p>
            <span class="text-sm font-semibold text-amber-600">{link.cta}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 mb-24 reveal">
      <h2 class="text-2xl font-semibold tracking-tight text-primary dark:text-stone-50 mb-8">Common first slices</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {capabilityLinks.map(link => (
          <a href={link.href} class="group rounded-xl border border-stone-200 dark:border-stone-800 bg-surface/50 dark:bg-stone-900/40 p-6 hover:border-amber-600/40 transition-colors">
            <h2 class="text-base font-semibold text-primary dark:text-stone-100 mb-3 group-hover:text-amber-600 transition-colors">{link.title}</h2>
            <p class="text-sm text-muted dark:text-stone-400 leading-relaxed mb-6">{link.text}</p>
            <span class="text-sm font-semibold text-amber-600">{link.cta}</span>
          </a>
        ))}
      </div>
    </section>

    <AIWorkflows />
    <Boundaries />

    <PageBottomCTA 
      title="Have a workflow in mind?"
      description="Send us the shortest useful version: what workflow is stuck, what systems are involved, and what good looks like."
      links={[
        { text: "AR Collections Automation", href: "/ar-collections" },
        { text: "Internal tools development", href: "/capabilities/internal-tools-development-gcc" },
        { text: "Retool development", href: "/capabilities/retool-development-gcc" },
        { text: "Workflow layer above ERP", href: "/capabilities/workflow-layer-above-erp" },
        { text: "Security", href: "/security" },
        { text: "How we work", href: "/how-we-work" }
      ]}
    />

  </main>

  <Footer />
</Layout>
