---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

import PageHeader from '../components/capabilities/PageHeader.astro';
import QuickAnswer from '../components/capabilities/QuickAnswer.astro';
import WhatWeDeliver from '../components/capabilities/WhatWeDeliver.astro';
import AIWorkflows from '../components/capabilities/AIWorkflows.astro';
import Boundaries from '../components/capabilities/Boundaries.astro';
import PageBottomCTA from '../components/capabilities/PageBottomCTA.astro';

// SEO constants
const seo = {
  title: "Capabilities | Binizam",
  description: "Internal workflow systems: operational UIs, controlled automation, integrations, reconciliation, and workflow reporting you can trust."
};
---

<Layout title={seo.title} description={seo.description}>
  <Navbar />

  <main class="z-10 relative flex-grow pt-32 pb-24">
    
    <PageHeader 
      title="Capabilities" 
      description="A scannable map of what we deliver—so you can confirm fit quickly or forward it internally." 
    />

    <QuickAnswer />
    <WhatWeDeliver />
    <AIWorkflows />
    <Boundaries />

    <PageBottomCTA 
      links={[
        { text: "How we work", href: "/how-we-work" },
        { text: "Security", href: "/security" },
        { text: "AR Collections Automation", href: "/ar-collections" }
      ]}
    />

  </main>

  <Footer />
</Layout>