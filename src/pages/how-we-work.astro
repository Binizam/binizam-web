---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

import Hero from '../components/how-we-work/Hero.astro';
import DeliveryModel from '../components/how-we-work/DeliveryModel.astro';
import ExampleFirstSlice from '../components/how-we-work/ExampleFirstSlice.astro';
import ReviewableOutputs from '../components/how-we-work/ReviewableOutputs.astro';
import Checkpoints from '../components/how-we-work/Checkpoints.astro';
import Hosting from '../components/how-we-work/Hosting.astro';
import AccessRequirements from '../components/how-we-work/AccessRequirements.astro';
import FinalCTA from '../components/how-we-work/FinalCTA.astro';

// SEO constants
const seo = {
  title: "How Binizam Builds Internal Workflow Systems | Binizam",
  description: "How Binizam delivers internal workflow systems in small slices: workflow mapping, queue design, approvals, integrations, QA, handover, and auditability."
};
---

<Layout title={seo.title} description={seo.description}>
  <Navbar />

  <main class="z-10 relative flex-grow pt-32 pb-24">
    <Hero />
    <DeliveryModel />
    <ExampleFirstSlice />
    <ReviewableOutputs />
    <Checkpoints />
    <Hosting />
    <AccessRequirements />
    <FinalCTA />
  </main>

  <Footer />
</Layout>
