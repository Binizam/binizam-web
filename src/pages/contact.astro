---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

import ContactHeader from '../components/contact/ContactHeader.astro';
import ContactGrid from '../components/contact/ContactGrid.astro';

// SEO constants 
const seo = {
  title: "Talk to an Engineer | Binizam",
  description: "Send Binizam a short note about your workflow problem, systems involved, sensitive approvals, and what good looks like. Engineer-led, no sales deck."
};
---

<Layout title={seo.title} description={seo.description}>
  <Navbar />

  <main class="z-10 relative flex-grow pt-32 pb-16">
    <ContactHeader />
    <ContactGrid />
  </main>

  <Footer />
</Layout>
