---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import ContentHero from '../../components/seo/ContentHero.astro';
import HubCards from '../../components/seo/HubCards.astro';
import RelatedLinks from '../../components/seo/RelatedLinks.astro';
import FAQAccordion from '../../components/seo/FAQAccordion.astro';
import { solutionHubHighlights, solutionPages, type FaqItem, type RelatedLink } from '../../data/siteContent';

const seo = {
  title: 'Accounts Receivable Automation Solutions for GCC Finance Teams | Binizam',
  description:
    'Explore AR automation solutions for collections, cash application, payment reconciliation, dispute workflows, collector worklists, and GCC finance operations.'
};

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Solutions', href: '/solutions/' }
];

const visual = {
  caption: 'Solutions map',
  cards: [
    {
      icon: 'solar:chart-2-linear',
      title: 'Start with the AR suite page',
      text: 'Use the broad AR automation page as the main commercial entry point.',
      label: 'Hub'
    },
    {
      icon: 'solar:git-branch-linear',
      title: 'Branch into module pages',
      text: 'Collections, cash app, disputes, reconciliation, and collector queue workflows.',
      label: 'Modules'
    },
    {
      icon: 'solar:map-point-linear',
      title: 'Localize for UAE and Saudi',
      text: 'Route GCC market intent to country-specific landing pages without duplicating system logic.',
      label: 'GCC'
    }
  ]
};

const faqs: FaqItem[] = [
  {
    q: 'Which AR solution page should a buyer start with?',
    a: 'Start with Accounts Receivable Automation if the buyer is evaluating the full AR operating model. Use AR Collections, Cash Application, or Disputes if the buyer already knows the workflow they want to fix first.'
  },
  {
    q: 'Can one workflow be implemented first?',
    a: 'Yes. The safest V1 is usually one queue, one exception class, or one country/team scope with a clear owner model and approval boundary.'
  }
];

const relatedLinks: RelatedLink[] = solutionPages.slice(0, 3).map((page) => ({
  eyebrow: 'Solution',
  label: page.h1.replace(/\.$/, ''),
  href: page.href,
  description: page.lead,
  icon: page.visual.cards[0]?.icon ?? 'solar:bolt-linear'
}));
---

<Layout
  title={seo.title}
  description={seo.description}
  breadcrumbs={breadcrumbs}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: seo.title,
    description: seo.description,
    url: new URL('/solutions/', Astro.site || 'https://binizam.com').toString()
  }}
>
  <Navbar />

  <main class="z-10 relative flex-grow">
    <Breadcrumbs items={breadcrumbs} />

    <ContentHero
      eyebrow="Solutions"
      h1="Solutions for accounts receivable workflows, reconciliation, and collections operations."
      lead="Explore the commercial AR automation pages that will anchor search demand and route buyers into the right workflow module or GCC country landing page."
      directAnswer="Binizam’s solution architecture should make one thing obvious: start from the AR suite page for broad buyer intent, then move into collections, cash application, disputes, reconciliation, collector queues, or GCC-localized landing pages depending on the workflow being evaluated."
      quickLinks={[
        { label: 'Solution cards', href: '#solution-cards' },
        { label: 'FAQ', href: '#faq' }
      ]}
      visual={visual}
      highlights={solutionHubHighlights}
      secondaryCtaHref="/guides/"
      secondaryCtaLabel="Read the guides"
    />

    <section id="solution-cards" class="max-w-6xl mx-auto px-6 pb-16">
      <div class="grid md:grid-cols-2 gap-5">
        {solutionPages.map((page, index) => (
          <a
            href={page.href}
            class={`group rounded-[2rem] border border-stone-200 dark:border-stone-800 bg-white/70 dark:bg-stone-950/60 p-7 shadow-sm hover:border-amber-600/40 hover:-translate-y-1 transition-all reveal ${index % 2 === 1 ? 'delay-100' : ''}`}
          >
            <div class="flex items-start justify-between gap-4">
              <div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-stone-200 dark:border-stone-700 bg-surface dark:bg-stone-800 text-amber-700 dark:text-amber-500">
                <iconify-icon icon={page.visual.cards[0]?.icon ?? 'solar:bolt-linear'} width="22" stroke-width="1.5"></iconify-icon>
              </div>
              <span class="rounded-full border border-amber-600/20 bg-amber-600/5 px-3 py-1 text-[0.65rem] font-mono uppercase tracking-[0.2em] text-amber-700 dark:text-amber-500">
                {page.scopeTag}
              </span>
            </div>
            <h2 class="mt-5 text-xl font-semibold tracking-tight text-primary dark:text-stone-50 group-hover:text-amber-600 transition-colors">
              {page.h1.replace(/\.$/, '')}
            </h2>
            <p class="mt-4 text-sm leading-7 text-stone-600 dark:text-stone-400">
              {page.lead}
            </p>
            <div class="mt-6 flex items-center gap-2 text-sm font-semibold text-amber-700 dark:text-amber-500">
              Open page
              <iconify-icon icon="solar:arrow-right-linear" width="16" stroke-width="1.5"></iconify-icon>
            </div>
          </a>
        ))}
      </div>
    </section>

    <HubCards cards={solutionHubHighlights} />
    <FAQAccordion faqs={faqs} />
    <RelatedLinks links={relatedLinks} />
  </main>

  <Footer />
</Layout>
