---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

import Hero from '../components/security/Hero.astro';
import SecurityGlance from '../components/security/SecurityGlance.astro';
import Principles from '../components/security/Principles.astro';
import DataBoundaries from '../components/security/DataBoundaries.astro';
import WhatWeLog from '../components/security/WhatWeLog.astro';
import Hosting from '../components/security/Hosting.astro';
import AccessRequirements from '../components/security/AccessRequirements.astro';
import FinalCTA from '../components/security/FinalCTA.astro';

// SEO constants
const seo = {
  title: "Security for Internal Workflow Systems | Binizam",
  description: "Security posture for internal workflow systems: least privilege, scoped permissions, audit logs, encryption, data minimization, and clear data boundaries."
};
---

<Layout title={seo.title} description={seo.description}>
  <Navbar />

  <main class="z-10 relative flex-grow pt-32 pb-24">
    <Hero />
    <SecurityGlance />
    <Principles />
    <DataBoundaries />
    <WhatWeLog />
    <Hosting />
    <AccessRequirements />
    <FinalCTA />
  </main>

  <Footer />
</Layout>
