---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

import PrivacyHeader from '../components/privacy/PrivacyHeader.astro';
import PolicyContent from '../components/privacy/PolicyContent.astro';

// SEO constants 
const seo = {
  title: "Privacy Policy | Binizam",
  description: "What we collect via contact, how we use it, retention basics, and how to reach us about privacy questions."
};
---

<Layout title={seo.title} description={seo.description}>
  <Navbar />

  <main class="z-10 relative flex-grow pt-32 pb-16">
    <PrivacyHeader />
    <PolicyContent />
  </main>

  <Footer />
</Layout>