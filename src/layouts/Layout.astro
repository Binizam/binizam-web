---
import '../styles/global.css';

interface Props {
    title: string;
    description?: string;
}

const { 
  title, 
  description = "Internal workflow systems: operational UIs, controlled automation, integrations, reconciliation, and workflow reporting you can trust." 
} = Astro.props;

// Determine if we are in a Vercel preview environment to prevent indexing
const isPreview = import.meta.env.VERCEL_ENV === 'preview';
---

<!doctype html>
<html class="scroll-smooth antialiased overflow-x-hidden" lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <title>{title}</title>
        
        {isPreview && <meta name="robots" content="noindex, nofollow" />}

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
        
        <script is:inline src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>

        <script is:inline>
            const theme = (() => {
              // 1. Check if user already has a saved preference
              if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                return localStorage.getItem('theme');
              }
              // 2. Otherwise, force 'light' as the default for everyone
              return 'light';
            })();
          
            if (theme === 'dark') {
              document.documentElement.classList.add('dark');
            } else {
              document.documentElement.classList.remove('dark');
            }
        </script>
    </head>
    <body class="font-sans text-primary bg-main dark:bg-[#1C1917] dark:text-stone-100 relative selection:bg-amber-500 selection:text-white flex flex-col min-h-screen overflow-x-hidden">
        
        <div class="fixed inset-0 pointer-events-none z-0">
            <div class="absolute inset-0 bg-main dark:bg-[#1C1917] transition-colors duration-500 ease-in-out"></div>
            <div class="absolute inset-0 bg-grid opacity-70 dark:opacity-50"></div>
        </div>

        <slot />

        <script>
            function initScrollReveal() {
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            requestAnimationFrame(() => {
                                entry.target.classList.add("active");
                            });
                            observer.unobserve(entry.target);
                        }
                    });
                }, { 
                    root: null, 
                    rootMargin: "0px 0px -50px 0px", 
                    threshold: 0.1 
                });

                document.querySelectorAll(".reveal, .reveal-right").forEach((el) => {
                    observer.observe(el);
                });
            }

            document.addEventListener('DOMContentLoaded', initScrollReveal);
            document.addEventListener('astro:page-load', initScrollReveal);
        </script>

        <style is:global>
            /* Smooth Theme Transition 
               This ensures that background and text colors fade instead of snapping.
            */
            html.dark body,
            html.dark .bg-main,
            html.dark .bg-surface,
            html.dark .text-primary,
            html.dark .text-muted {
                transition: background-color 0.5s ease-in-out, border-color 0.5s ease-in-out, color 0.5s ease-in-out;
            }

            body, .bg-main, .bg-surface, .text-primary, .text-muted {
                transition: background-color 0.5s ease-in-out, border-color 0.5s ease-in-out, color 0.5s ease-in-out;
            }
        </style>
    </body>
</html>